// FAQ Questions and Answers
"help_faq_q1" = "Jak zarejestrować mojego pupila?";
"help_faq_a1" = "Możesz zarejestrować swojego pupila w menu 'Moje Pupile' klikając 'Dodaj Nowego Zwierzaka'. Wypełnij wymagane informacje i prześlij jedno lub więcej zdjęć.";
"help_faq_q2" = "Jakie informacje powinienem podać w profilu mojego pupila?";
"help_faq_a2" = "Imię pupila podałeś już przy zamawianiu adresówki i pojawi się ono w profilu pupila po aktywacji adresówki. Wprowadź gatunek i rasę. Aby zapobiec nadużyciom, te dane można wprowadzić tylko raz. Jeśli popełnisz błąd, skontaktuj się z nami, a pomożemy. Tutaj możesz też dodać wagę, wiek, kolor i wszelkie cechy szczególne lub typowe zachowania kota/psa. Możesz też przesłać zdjęcia. Ty decydujesz, jakie informacje będą widoczne o Twoim pupilu, jeśli się zgubi.";
"help_faq_q3" = "Jak działa adresówka z kodem QR?";
"help_faq_a3" = "Każdy pupil otrzymuje unikalną adresówkę z kodem QR. Ten kod jest powiązany z profilem Twojego pupila. Gdy ktoś zeskanuje kod QR telefonem, może natychmiast zobaczyć profil pupila i dane kontaktowe oznaczone jako publiczne.";
"help_faq_q4" = "Czy mogę później zaktualizować dane mojego pupila?";
"help_faq_a4" = "Tak! Możesz aktualizować dane pupila w dowolnym momencie w sekcji 'Moje Pupile' wybierając pupila i klikając 'Edytuj Profil'. Możesz aktualizować wszystkie pola z wyjątkiem imienia, gatunku i rasy, łącznie ze zdjęciami. Zmiany są zapisywane natychmiast.";
"help_faq_q5" = "Jak zamówić adresówkę zastępczą?";
"help_faq_a5" = "Przejdź do strony 'Strona główna / Moje konto' i dotknij 'Zamów adresówkę zastępczą'. Wybierz, który pupil potrzebuje nowej adresówki. Uprawnienia do wymiany zależą od twojego konta Senra; szczegóły na senra.pet.";
"help_faq_q6" = "Jak aktywować adresówkę po jej otrzymaniu?";
"help_faq_a6" = "Pobierz aplikację mobilną SENRA z Google Play Store lub App Store! Otwórz ją i przejdź do menu 'Aktywuj', skieruj aparat telefonu na kod QR na adresówce! Zeskanowanie kodu QR łączy adresówkę z Twoim kontem. Następnie musisz wybrać istniejącego pupila lub utworzyć nowy profil.";
"help_faq_q7" = "Czy mogę podarować adresówkę SENRA?";
"help_faq_a7" = "Tak! Plakietki SENRA to świetne prezenty dla opiekunów pupili. Zamów adresówkę ze swojego konta — gdy obdarowany ją otrzyma, może zeskanować kod QR, utworzyć konto i aktywować adresówkę dla swojego pupila.";
"help_faq_q8" = "Co powinienem zrobić, jeśli mój pupil zaginął?";
"help_faq_a8" = "Przejdź do 'Moje Pupile', kliknij menu na karcie pupila i wybierz 'Oznacz jako Zaginionego'. To tworzy 'alert o zaginionym pupilu' wysyłany do wszystkich członków społeczności SENRA w promieniu 10 km. Weterynarze i schroniska również są powiadamiani. Otrzymasz natychmiastowe powiadomienie o każdym spostrzeżeniu.";
"help_faq_q9" = "Jak działają alerty o zaginionych pupilach?";
"help_faq_a9" = "Gdy oznaczysz kota lub psa jako zaginionego, tworzony jest alert ze zdjęciem i danymi pupila. Użytkownicy SENRA w promieniu 10 km są natychmiast powiadamiani, a pupil pojawia się na mapie 'Zaginione Pupile'. Weterynarze i schroniska zarejestrowane w systemie SENRA również otrzymują alert.";
"help_faq_q10" = "Jak zamówić adresówkę zastępczą?";
"help_faq_a10" = "Przejdź do 'Strona Główna/Moje Konto' i kliknij 'Zamów Plakietkę Zastępczą'. Subskrybenci Maximum i Standard mogą żądać bezpłatnych zamienników, członkowie Starter płacą koszt wysyłki.";
"help_faq_q11" = "Czym jest program poleceń?";
"help_faq_a11" = "W menu Polecenia na stronie Profilu możesz wygenerować osobisty kod polecający. Podziel się nim z przyjaciółmi i rodziną. Gdy ktoś użyje Twojego kodu i wykupi płatny plan (Standard lub Maximum), Ty i Twój przyjaciel otrzymujecie 2 miesiące za darmo.";
"help_faq_q12" = "Do jakich krajów wysyłacie?";
"help_faq_a12" = "Obecnie wysyłamy do Węgier, Słowacji, Czech, Austrii, Rumunii, Chorwacji, Hiszpanii, Włoch, Francji, Niemiec, Norwegii i Portugalii. Wysyłka krajowa na Węgrzech: {{huPostapoint}} (PostaPont) lub {{huHome}} (dostawa do domu). Wysyłka międzynarodowa: {{intlPrice}} za zamówienie.";
"help_faq_q13" = "Czy mogę mieć wiele pupili na jednym koncie?";
"help_faq_a13" = "Tak. Możesz zarejestrować wielu pupili na jednym koncie. Szczegóły konta na senra.pet.";
"help_faq_q14" = "Jak zgłosić znalezione pupila?";
"help_faq_a14" = "Jeśli pupila ma adresówkę SENRA, po prostu zeskanuj kod QR aparatem — nie potrzebujesz aplikacji. Możesz zobaczyć profil pupila i udostępnić swoją lokalizację opiekunowi.";
"help_faq_q15" = "Czy moje dane osobowe są bezpieczne?";
"help_faq_a15" = "Tak. Ty kontrolujesz, jakie dane są widoczne po zeskanowaniu adresówki. W 'Ustawienia' > 'Ustawienia Prywatności' możesz wybrać, czy pokazywać telefon, email czy adres. Logowanie jest chronione jednorazowym kodem weryfikacyjnym. Możesz usunąć konto i dane w dowolnym momencie.";
"help_faq_q16" = "Zgubiliśmy adresówkę lub się uszkodziła — co robić?";
"help_faq_a16" = "Nie martw się — cyfrowy profil twojego pupila jest bezpieczny i nie jest przechowywany na adresówce. Przejdź do strony Konto i dotknij 'Zamów wymianę'. Połączymy nową adresówkę ze świeżym kodem QR z twoim istniejącym profilem. Uprawnienia do wymiany zależą od twojego konta Senra; szczegóły na senra.pet. Stara adresówka jest dezaktywowana natychmiast po złożeniu zamówienia wymiany.";
"help_faq_q17" = "Moja adresówka nie skanuje się — co robić?";
"help_faq_a17" = "Spróbuj następujących rzeczy: wyczyść powierzchnię adresówki wilgotną ściereczką, zapewnij dobre oświetlenie, trzymaj aparat telefonu stabilnie około 10–15 cm od adresówki i sprawdź, czy aplikacja aparatu lub czytnik QR działa. Jeśli kod QR jest zarysowany lub zużyty, zamów wymianę na stronie 'Strona główna / Moje konto'.";
"help_faq_q18" = "Znalazłem pupila bez adresówki SENRA — co mogę zrobić?";
"help_faq_a18" = "Sprawdź mapę Zaginionych zwierząt na stronie SENRA (senra.pet) — być może ten pupil został już zgłoszony jako zaginiony w twojej okolicy. Alerty o zaginionych zwierzętach możesz też przeglądać w aplikacji. Zawieź zwierzę do najbliższej kliniki weterynaryjnej, aby odczytano jego mikroczip. Jeśli odnaleziony pupil ma zawieszkę SENRA, zeskanuj kod QR aparatem telefonu — pojawią się dane kontaktowe właściciela.";
"help_faq_q19" = "Czy mogę zmienić swój adres email?";
"help_faq_a19" = "Twój główny email służy jako identyfikator konta i nie można go bezpośrednio zmienić. Możesz dodać dodatkowy email w 'Ustawienia' > 'Dane Kontaktowe'. Jeśli koniecznie musisz zmienić główny email, skontaktuj się z nami na hello@senra.pet.";
"help_faq_q20" = "Jaka jest różnica między mikrochipem a adresówką QR SENRA?";
"help_faq_a20" = "Mikrochip to mały implant pod skórą pupila przechowujący unikalny 15-cyfrowy identyfikator — ale wymaga specjalnego czytnika. Adresówka QR SENRA może być łatwo zeskanowana dowolnym aparatem smartfona, natychmiast wyświetlając pełny profil, zdjęcie i zatwierdzone dane kontaktowe. Znalazca może też udostępnić współrzędne GPS.";
"help_faq_q21" = "Co się stanie z moimi danymi, jeśli anuluję subskrypcję?";
"help_faq_a21" = "Jeśli anulujesz, zachowujesz dostęp do płatnych funkcji do końca okresu rozliczeniowego. Potem konto przechodzi na bezpłatny plan Starter. Profile, zdjęcia i adresówki QR pozostają aktywne. Dane nie są usuwane. Aby trwale usunąć wszystko, użyj opcji Usuń Konto w Ustawieniach.";
"help_faq_q22" = "Jak mogę zarejestrować moją klinikę lub schronisko w SENRA?";
"help_faq_a22" = "Kliniki weterynaryjne i schroniska mogą się zarejestrować na senra.pet/register-vet-shelter. Wypełnij dane i wyślemy email weryfikacyjny. Po potwierdzeniu automatycznie wysyłamy powiadomienia gdy pupile giną w okolicy. Bez opłat i bez logowania.";
"help_faq_q23" = "Jak mogę podzielić się historią sukcesu, jeśli mój pupil został odnaleziony?";
"help_faq_a23" = "Gdy oznaczysz pupila jako 'Odnaleziony', zapytamy, czy chcesz podzielić się dobrą wiadomością. Możesz opublikować krótką historię. Publiczne historie pojawiają się na mapie 'Odnalezione Pupile'.";
"help_faq_q24" = "Jakie przeglądarki i urządzenia są obsługiwane?";
"help_faq_a24" = "SENRA działa we wszystkich przeglądarkach, w tym Chrome, Safari, Firefox i Edge, na urządzeniach mobilnych i stacjonarnych. Skanowanie adresówki QR działa z dowolnym aparatem smartfona — znalazca nie potrzebuje aplikacji SENRA ani konta.";
"help_faq_q25" = "Czy mogę zamówić wiele plakietek dla moich pupili naraz?";
"help_faq_a25" = "Tak, możesz zamówić adresówki dla wszystkich pupili jednocześnie. Po dostawie zeskanuj każdą, aby aktywować i przypisać do odpowiedniego profilu.";
"help_faq_q26" = "Jak alerty o zaginionych pupilach docierają do weterynarzy i schronisk?";
"help_faq_a26" = "Gdy oznaczysz pupila jako 'Zaginionego', SENRA automatycznie wysyła alerty emailowe do wszystkich zarejestrowanych weterynarzy i schronisk w okolicy. Im więcej zarejestrowanych, tym lepiej działa sieć.";
"help_faq_q27" = "Czy mogę przenieść adresówkę na inne pupila?";
"help_faq_a27" = "Nie. Każda adresówka QR jest trwale powiązana z profilem jednego pupila. Jeśli pupil umrze lub nie potrzebujesz już adresówki, staje się po prostu nieaktywna. Zamów nową adresówkę dla nowego pupila na stronie SENRA.";
"help_faq_q28" = "Jak mogę zarejestrować klinikę weterynaryjną mojego pupila lub schronisko, z którego adoptowałem pupila, w sieci SENRA?";
"help_faq_a28" = "Kliniki weterynaryjne i schroniska mogą się zarejestrować na senra.pet/register-vet-shelter. Wypełnij dane i wyślemy email weryfikacyjny. Po potwierdzeniu automatycznie wysyłamy powiadomienia — pomagając zaginionym pupilom szybciej wrócić do domu. Bez opłat i bez logowania.";
