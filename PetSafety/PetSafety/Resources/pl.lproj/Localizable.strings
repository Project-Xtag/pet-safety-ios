// Elementy przewodnika
"help_guide_qr_tags_title" = "Nieśki z kodem QR";
"help_guide_qr_tags_desc" = "Każda nieśka SENRA zawiera unikalny kod QR prowadzący do cyfrowego profilu twojego pupila. Każdy, kto znajdzie twoje pupila, może zeskanować kod aparatem telefonu — bez konieczności pobierania aplikacji. Skaner natychmiast widzi zdjęcie, imię, informacje medyczne i twoje dane kontaktowe. Może też udostępnić swoją lokalizację GPS, dzięki czemu będziesz wiedział/a dokładnie, gdzie jest twoje pupila. Nieśki działają ze wszystkimi nowoczesnymi smartfonami.";
"help_guide_materials_title" = "Materiały i trwałość nieśek";
"help_guide_materials_desc" = "Nieśki SENRA są wykonane z trwałego, lekkiego metalu z powłoką epoksydową zapewniającą dodatkową ochronę. Są wodoodporne i odporne na UV, odpowiednie na każde warunki pogodowe. Kod QR jest wydrukowany tuszem odpornym na blaknięcie, aby pozostać czytelnym przez długi czas. Nieśki bezpiecznie mocują się do obroży pupila. Jeśli nieśka ulegnie uszkodzeniu lub kod QR przestanie się skanować, możesz zamówić zamiennik na stronie Konto — bezpłatnie dla członków planów Standard i Maximum.";
"help_guide_emergency_title" = "Kontakt alarmowy i alerty";
"help_guide_emergency_desc" = "Gdy ktoś zeskanuje adresówkę twojego pupila, otrzymasz natychmiastowe powiadomienie e-mailem z lokalizacją znalazcy. Członkowie planów Standard i Maximum otrzymują też alerty SMS dla szybszej reakcji. Jeśli oznaczysz pupila jako zaginione, alert społecznościowy jest wysyłany do wszystkich użytkowników SENRA w promieniu 10km, a zarejestrowani weterynarze i schroniska w twoim rejonie są również powiadamiani. Każdy ze społeczności może zgłaszać spostrzeżenia z lokalizacją, budując ślad, który pomoże ci odnaleźć pupila.";
"help_guide_profile_title" = "Zarządzanie profilem pupila";
"help_guide_profile_desc" = "Cyfrowy profil twojego pupila to serce SENRA. Dodaj podstawowe dane: imię, gatunek, rasę, wiek i wyraźne zdjęcie. Możesz też podać informacje medyczne (alergie, leki, schorzenia), numer mikrochipa i cechy charakterystyczne ułatwiające identyfikację. Prześlij wiele zdjęć do galerii. Wszystkie informacje można aktualizować w dowolnym momencie w sekcji „Moje pupile”. Możesz kontrolować, które z twoich danych osobowych (telefon, e-mail, adres) są widoczne dla osób skanujących adresówkę.";
"help_guide_missing_alerts_title" = "Alerty o zaginionych pupilach i spostrzeżenia";
"help_guide_missing_alerts_desc" = "Jeśli twoje pupila zaginęło, oznacz je jako zaginione w „Moje pupile”, aby natychmiast utworzyć alert społecznościowy. Zdjęcie i dane twojego pupila pojawią się na mapie zaginionych pupili widocznej dla wszystkich użytkowników SENRA w twoim rejonie. Członkowie społeczności mogą zgłaszać spostrzeżenia z lokalizacją GPS, które otrzymasz jako powiadomienia. Zarejestrowani weterynarze i schroniska są również alertowani. Po odnalezieniu pupila oznacz je jako znalezione i opcjonalnie podziel się historią powrotu do domu, aby zainspirować społeczność.";
"help_guide_community_title" = "Społeczność i odnalezione pupile";
"help_guide_community_desc" = "Siłą SENRA jest jej społeczność. Mapa zaginionych pupili pokazuje aktywne alerty w pobliżu — sprawdź, czy w twoim rejonie zgłoszono jakieś zaginione pupile. Strona odnalezionych pupili celebruje udane reunifikacje z historiami opiekunów. Możesz zarejestrować lokalnego weterynarza lub schronisko w SENRA, aby automatycznie otrzymywali alerty o zaginionych pupilach, pomagając tworzyć silniejszą sieć bezpieczeństwa dla wszystkich pupili w twoim rejonie.";
