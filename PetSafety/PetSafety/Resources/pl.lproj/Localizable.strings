// Elementy FAQ
"help_faq_q1" = "Jak mogę utworzyć konto?";
"help_faq_a1" = "Senra używa logowania bez hasła. Wystarczy podać adres e-mail na stronie logowania, a my wyślemy 6-cyfrowy kod weryfikacyjny. Wpisz kod, aby się zalogować. Jeśli jesteś nowy/a, konto zostaje utworzone automatycznie przy pierwszym logowaniu — nie jest wymagana osobna rejestracja.";
"help_faq_q2" = "Jak zarejestrować swoje zwierzę?";
"help_faq_a2" = "Przejdź do „Moje zwierzęta” i dotknij „Dodaj nowe zwierzę”. Podaj imię, gatunek, rasę i wiek pupila, a następnie prześlij zdjęcie. Jeśli masz już zawieszk QR, możesz ją zeskanować podczas rejestracji, aby od razu połączyć ją z profilem zwierzęcia.";
"help_faq_q3" = "Jakie informacje należy podać w profilu zwierzęcia?";
"help_faq_a3" = "Podaj co najmniej imię, gatunek i wyraźne zdjęcie. Aby zwiększyć szanse na szybki powrót do domu w razie zaginięcia, dodaj też: rasę, wiek, wagę, kolor, numer mikrochipa, uwagi medyczne, alergie, leki i cechy charakterystyczne (wzory, blizny itp.). Im więcej szczegółów, tym łatwiej komuś zidentyfikować twoje zwierzę.";
"help_faq_q4" = "Jak działa zawieszka z kodem QR?";
"help_faq_a4" = "Każda zawieszka Senra ma unikalny kod QR. Gdy ktoś znajdzie twoje zwierzę i zeskanuje go aparatem telefonu, natychmiast zobaczy profil pupila — zdjęcie, imię, informacje medyczne i twoje dane kontaktowe. Może też udostępnić swoją lokalizację GPS, dzięki czemu będziesz wiedział/a dokładnie, gdzie jest twoje zwierzę. Osoba skanująca nie musi pobierać aplikacji.";
"help_faq_q5" = "Co się dzieje, gdy ktoś zeskanuje zawieszk mojego zwierzęcia?";
"help_faq_a5" = "Skaner widzi publiczny profil twojego pupila ze szczegółami, które zdecydowałeś/aś się udostępnić (imię, zdjęcie, informacje medyczne, dane kontaktowe). Może dotknąć „Znalazłem to zwierzę!”, aby udostępnić ci swoją lokalizację. Otrzymasz natychmiastowe powiadomienie e-mailem (i SMS-em, jeśli masz plan Standard lub Maximum) z lokalizacją i danymi znalazcy.";
"help_faq_q6" = "Jak aktywować zawieszk po jej otrzymaniu?";
"help_faq_a6" = "Przejdź do „Skanuj zawieszk” w aplikacji i skieruj aparat telefonu na kod QR na zawieszce. Spowoduje to połączenie zawieszki z twoim kontem. Zostaniesz poproszony/a o wybranie istniejącego zwierzęcia lub utworzenie nowego profilu. Po aktywacji wybierz plan subskrypcji.";
"help_faq_q7" = "Czy mogę zaktualizować informacje o zwierzęciu po rejestracji?";
"help_faq_a7" = "Tak — możesz edytować profil zwierzęcia w dowolnym momencie. Przejdź do „Moje zwierzęta”, wybierz zwierzę i dotknij „Edytuj”. Możesz zaktualizować dowolne pole, w tym zdjęcia. Zmiany są zapisywane natychmiast.";
"help_faq_q8" = "Co zrobić, gdy moje zwierzę zaginęło?";
"help_faq_a8" = "Przejdź do „Moje zwierzęta” i dotknij menu na karcie zwierzęcia, a następnie wybierz „Oznacz jako zaginione”. Spowoduje to utworzenie alertu o zaginionym zwierzęciu widocznego dla społeczności Senra w twoim rejonie. Osoby w pobliżu zobaczą alert i będą mogły zgłaszać spostrzeżenia z informacją o lokalizacji. Zostaniesz natychmiast powiadomiony/a o wszelkich spostrzeżeniach.";
"help_faq_q9" = "Jak działają alerty o zaginionych zwierzętach?";
"help_faq_a9" = "Gdy oznaczysz zwierzę jako zaginione, tworzony jest alert ze zdjęciem i danymi pupila. Inni użytkownicy Senra w promieniu 10km mogą zobaczyć alert na mapie zaginionych zwierząt. Każdy ze społeczności może zgłosić spostrzeżenie z lokalizacją GPS, które otrzymasz jako powiadomienie. Zarejestrowani weterynarze i schroniska w twoim rejonie również otrzymują alert.";
"help_faq_q10" = "Jak zamówić zamienninik zawieszki?";
"help_faq_a10" = "Przejdź do strony Konto i dotknij „Zamów zamiennik”. Wybierz zwierzę, które potrzebuje nowej zawieszki. Członkowie planu Maximum otrzymują nieograniczone bezpłatne zamienniki, członkowie planu Standard otrzymują jeden bezpłatny zamiennik rocznie, a członkowie planu Starter mogą zamawiać zamienniki za małą opłatą za wysyłkę.";
"help_faq_q11" = "Co to jest program poleceń?";
"help_faq_a11" = "Przejdź na stronę Polecenia, aby wygenerować swój osobisty kod polecenia. Udostępnij go znajomym i rodzinie. Gdy ktoś użyje Twojego kodu i subskrybuje plan płatny (Standard lub Maximum), oboje otrzymacie 2 miesiące za darmo. Możesz śledzić swoje polecenia na stronie Polecenia.";
"help_faq_q12" = "Do jakich krajów wysyłacie?";
"help_faq_a12" = "Wysyłamy obecnie do Węgier, Słowacji, Czech, Austrii, Rumunii, Chorwacji, Hiszpanii i Portugalii. Wysyłka na Węgry kosztuje %1$@ (PostaPont) lub %2$@ (dostawa do domu). Wysyłka międzynarodowa to %3$@ za zamówienie.";
"help_faq_q13" = "Czy mogę mieć kilka zwierząt na jednym koncie?";
"help_faq_a13" = "Tak. W planie Starter (bezpłatnym) możesz zarejestrować do 10 zwierząt. Plan Standard obsługuje 1 zwierzę. Plan Maximum obsługuje do 10 zwierząt. Możesz zmienić plan w dowolnym momencie na stronie Konto.";
"help_faq_q14" = "Jak zgłosić znalezione zwierzę?";
"help_faq_a14" = "Jeśli zwierzę ma zawieszk Senra, wystarczy zeskanować kod QR aparatem telefonu — nie jest potrzebna aplikacja. Zobaczysz profil zwierzęcia i będziesz mógł/mogła udostępnić swoją lokalizację właścicielowi. Jeśli nie ma zawieszki, możesz sprawdzić mapę zaginionych zwierząt na stronie Senra, aby zobaczyć, czy zwierzę zostało zgłoszone jako zaginione w twoim rejonie.";
"help_faq_q15" = "Czy moje dane osobowe są bezpieczne?";
"help_faq_a15" = "Tak. Masz pełną kontrolę nad tym, jakie informacje są widoczne, gdy ktoś skanuje zawieszk twojego zwierzęcia. W Ustawieniach > Prywatność możesz wybrać, czy pokazywać numer telefonu, e-mail i adres. Logowanie jest zabezpieczone jednorazowymi kodami weryfikacyjnymi — nie ma haseł do kradzieży. Możesz usunąć konto i wszystkie dane w dowolnym momencie.";
"help_faq_q16" = "Zgubiłem/am zawieszk lub jest uszkodzona — co zrobić?";
"help_faq_a16" = "Nie martw się — cyfrowy profil twojego zwierzęcia jest bezpieczny i nie jest przechowywany na samej zawieszce. Przejdź na stronę Konto i dotknij „Zamów zamiennik”. Nowa zawieszka ze świeżym kodem QR zostanie połączona z twoim istniejącym profilem zwierzęcia. Członkowie planów Standard i Maximum mogą prosić o nieograniczone bezpłatne zamienniki, a członkowie Startera płacą małą opłatę za wysyłkę. Twoja stara zawieszka przestanie działać po aktywacji nowej.";
"help_faq_q17" = "Moja zawieszka nie skanuje się — jak to naprawić?";
"help_faq_a17" = "Spróbuj następujących kroków: wyczyść powierzchnię zawieszki wilgotną ściereczką, zapewnij dobre oświetlenie, trzymaj aparat telefonu stabilnie około 10-15cm od zawieszki i upewnij się, że aparat lub skaner QR działa. Jeśli kod QR jest porysowany lub wyblakły, możesz użyć opcji ręcznego wprowadzania kodu w aplikacji w sekcji „Skanuj zawieszk”. Jeśli zawieszka jest zbyt zniszczona, zamów bezpłatny zamiennik na stronie Konto (plany Standard i Maximum).";
"help_faq_q18" = "Znalazłem/am zwierzę bez zawieszki Senra — co mogę zrobić?";
"help_faq_a18" = "Sprawdź mapę zaginionych zwierząt na stronie Senra (senra.pet) — zwierzę mogło zostać zgłoszone jako zaginione w twoim rejonie. Alerty o zaginionych zwierzętach możesz przeglądać bez konta. Jeśli znajdziesz dopasowanie, możesz zgłosić spostrzeżenie z lokalizacją, aby pomóc zreunifikować zwierzę z właścicielem. Możesz też zabrać zwierzę do lokalnego weterynarza w celu sprawdzenia mikrochipa.";
"help_faq_q19" = "Czy mogę zmienić adres e-mail?";
"help_faq_a19" = "Twój główny adres e-mail służy jako identyfikator konta i nie można go bezpośrednio zmienić. Jeśli chcesz używać innego e-maila, możesz dodać zapasowy w Ustawieniach > Dane kontaktowe — będzie on widoczny na profilu twojego zwierzęcia. Jeśli absolutnie potrzebujesz zmienić główny e-mail, skontaktuj się z naszym zespołem wsparcia, a pomożemy ci przenieść konto.";
"help_faq_q20" = "Jaka jest różnica między mikrochipem a zawieszką QR Senra?";
"help_faq_a20" = "Mikrochip to mały implant pod skórą twojego zwierzęcia, który przechowuje unikalny numer identyfikacyjny — ale wymaga specjalnego skanera (zazwyczaj dostępnego tylko u weterynarzy i w schroniskach) do odczytu. Zawieszka QR Senra działa natychmiast z aparatem dowolnego smartfona, pokazując pełny profil twojego zwierzęcia, zdjęcie i dane kontaktowe na miejscu. Osoba, która znajdzie twoje zwierzę, może też udostępnić ci swoją lokalizację GPS. Zalecamy używanie obu: mikrochipa jako stałego zabezpieczenia, a zawieszki Senra do natychmiastowej, codziennej identyfikacji.";
"help_faq_q21" = "Co stanie się z moimi danymi, jeśli anuluję subskrypcję?";
"help_faq_a21" = "Jeśli anulujesz subskrypcję, zachowasz dostęp do płatnych funkcji do końca bieżącego okresu rozliczeniowego. Potem twoje konto automatycznie przejdzie na bezpłatny plan Starter. Profile zwierząt, zdjęcia i zawieszki QR pozostają aktywne — tracisz jedynie dostęp do funkcji premium, takich jak powiadomienia SMS, alerty weterynarzy i bezpłatne zamienniki zawieszek. Twoje dane nigdy nie są usuwane po anulowaniu. Aby trwale usunąć wszystkie dane, użyj opcji Usunięcie konta w Ustawieniach.";
"help_faq_q22" = "Jak zarejestrować weterynarza lub schronisko w Senra?";
"help_faq_a22" = "Weterynarze i schroniska mogą rejestrować się na stronie senra.pet/register-vet-shelter. Wypełnij dane gabinetu lub organizacji, a my wyślemy e-mail weryfikacyjny. Po potwierdzeniu automatycznie będziesz otrzymywać alerty e-mail, gdy zwierzęta zaginą w twoim rejonie — pomagając reunifikować zagubione zwierzęta z ich rodzinami. Rejestracja jest bezpłatna i nie wymaga logowania. Właściciele zwierząt mogą też zarejestrować swojego lokalnego weterynarza w ich imieniu.";
"help_faq_q23" = "Jak podzielić się historią sukcesu, gdy moje zwierzę zostanie odnalezione?";
"help_faq_a23" = "Gdy oznaczysz swoje zwierzę jako znalezione w „Moje zwierzęta”, zostaniesz zapytany/a, czy chcesz podzielić się historią powrotu do domu. Możesz dodać krótką wiadomość o tym, jak twoje zwierzę zostało odnalezione i potwierdzić miejsce reunifikacji. Publiczne historie pojawiają się na mapie odnalezionych zwierząt, inspirując społeczność i pokazując, że system działa. Możesz też opublikować lub usunąć historię sukcesu później ze strony profilu zwierzęcia.";
"help_faq_q24" = "Które przeglądarki i urządzenia są obsługiwane?";
"help_faq_a24" = "Senra działa we wszystkich nowoczesnych przeglądarkach, w tym Chrome, Safari, Firefox i Edge na urządzeniach mobilnych i stacjonarnych. Skanowanie zawieszek QR działa z aparatem dowolnego smartfona — osoba znajdująca twoje zwierzę nie potrzebuje aplikacji Senra ani nawet konta. Powiadomienia push są obsługiwane w Chrome i Edge na komputerach stacjonarnych i Androidzie. Dla najlepszych wyników zalecamy używanie aktualnej przeglądarki na telefonie.";
"help_faq_q25" = "Czy mogę zamówić zawieszki dla kilku zwierząt naraz?";
"help_faq_a25" = "Każde zamówienie zawieszek zawiera zawieszki dla imion zwierząt podanych podczas realizacji zamówienia. Możesz podać kilka imion zwierząt w jednym zamówieniu. Po otrzymaniu zawieszek zeskanuj każdą, aby ją aktywować i połączyć z odpowiednim profilem zwierzęcia. Jeśli później potrzebujesz zawieszek dla kolejnych zwierząt, możesz składać dodatkowe zamówienia na stronie Konto w dowolnym momencie.";
"help_faq_q26" = "Jak alerty o zaginionych zwierzętach trafiają do weterynarzy i schronisk?";
"help_faq_a26" = "Gdy oznaczysz swoje zwierzę jako zaginione, Senra automatycznie wysyła alerty e-mail do wszystkich zweryfikowanych weterynarzy i schronisk zarejestrowanych w twoim rejonie. Oznacza to, że lokalni specjaliści od zwierząt są natychmiast świadomi zaginięcia twojego pupila i mogą go wypatrywać. Im więcej weterynarzy i schronisk jest zarejestrowanych w twoim rejonie, tym silniejsza sieć bezpieczeństwa. Możesz pomóc, zachęcając własnego weterynarza do rejestracji w Senra.";
"help_faq_q27" = "Czy mogę przenieść zawieszk na inne zwierzę?";
"help_faq_a27" = "Każda zawieszka QR jest trwale połączona z jednym profilem zwierzęcia i nie można jej przypisać ponownie. Jeśli zwierzę umrze lub zawieszka nie jest już potrzebna, stara zawieszka po prostu staje się nieaktywna. Aby oznaczyć nowe zwierzę, zamów nową zawieszk na stronie Konto. Jeśli masz plan Standard lub Maximum, możesz być uprawniony/a do bezpłatnej zawieszki zamiennej dla nowego zwierzęcia.";
// Elementy przewodnika
"help_guide_qr_tags_title" = "Zawieszki z kodem QR";
"help_guide_qr_tags_desc" = "Każda zawieszka Senra zawiera unikalny kod QR prowadzący do cyfrowego profilu twojego zwierzęcia. Każdy, kto znajdzie twoje zwierzę, może zeskanować kod aparatem telefonu — bez konieczności pobierania aplikacji. Skaner natychmiast widzi zdjęcie, imię, informacje medyczne i twoje dane kontaktowe. Może też udostępnić swoją lokalizację GPS, dzięki czemu będziesz wiedział/a dokładnie, gdzie jest twoje zwierzę. Zawieszki działają ze wszystkimi nowoczesnymi smartfonami.";
"help_guide_materials_title" = "Materiały i trwałość zawieszek";
"help_guide_materials_desc" = "Zawieszki Senra są wykonane z trwałego, lekkiego metalu z powłoką epoksydową zapewniającą dodatkową ochronę. Są wodoodporne i odporne na UV, odpowiednie na każde warunki pogodowe. Kod QR jest wydrukowany tuszem odpornym na blaknięcie, aby pozostać czytelnym przez długi czas. Zawieszki bezpiecznie mocują się do obroży zwierzęcia. Jeśli zawieszka ulegnie uszkodzeniu lub kod QR przestanie się skanować, możesz zamówić zamiennik na stronie Konto — bezpłatnie dla członków planów Standard i Maximum.";
"help_guide_emergency_title" = "Kontakt alarmowy i alerty";
"help_guide_emergency_desc" = "Gdy ktoś zeskanuje zawieszk twojego zwierzęcia, otrzymasz natychmiastowe powiadomienie e-mailem z lokalizacją znalazcy. Członkowie planów Standard i Maximum otrzymują też alerty SMS dla szybszej reakcji. Jeśli oznaczysz zwierzę jako zaginione, alert społecznościowy jest wysyłany do wszystkich użytkowników Senra w promieniu 10km, a zarejestrowani weterynarze i schroniska w twoim rejonie są również powiadamiani. Każdy ze społeczności może zgłaszać spostrzeżenia z lokalizacją, budując ślad, który pomoże ci odnaleźć zwierzę.";
"help_guide_profile_title" = "Zarządzanie profilem zwierzęcia";
"help_guide_profile_desc" = "Cyfrowy profil twojego zwierzęcia to serce Senra. Dodaj podstawowe dane: imię, gatunek, rasę, wiek i wyraźne zdjęcie. Możesz też podać informacje medyczne (alergie, leki, schorzenia), numer mikrochipa i cechy charakterystyczne ułatwiające identyfikację. Prześlij wiele zdjęć do galerii. Wszystkie informacje można aktualizować w dowolnym momencie w sekcji „Moje zwierzęta”. Możesz kontrolować, które z twoich danych osobowych (telefon, e-mail, adres) są widoczne dla osób skanujących zawieszk.";
"help_guide_missing_alerts_title" = "Alerty o zaginionych zwierzętach i spostrzeżenia";
"help_guide_missing_alerts_desc" = "Jeśli twoje zwierzę zaginęło, oznacz je jako zaginione w „Moje zwierzęta”, aby natychmiast utworzyć alert społecznościowy. Zdjęcie i dane twojego pupila pojawią się na mapie zaginionych zwierząt widocznej dla wszystkich użytkowników Senra w twoim rejonie. Członkowie społeczności mogą zgłaszać spostrzeżenia z lokalizacją GPS, które otrzymasz jako powiadomienia. Zarejestrowani weterynarze i schroniska są również alertowani. Po odnalezieniu zwierzęcia oznacz je jako znalezione i opcjonalnie podziel się historią powrotu do domu, aby zainspirować społeczność.";
"help_guide_community_title" = "Społeczność i odnalezione zwierzęta";
"help_guide_community_desc" = "Siłą Senra jest jej społeczność. Mapa zaginionych zwierząt pokazuje aktywne alerty w pobliżu — sprawdź, czy w twoim rejonie zgłoszono jakieś zaginione zwierzęta. Strona odnalezionych zwierząt celebruje udane reunifikacje z historiami właścicieli. Możesz zarejestrować lokalnego weterynarza lub schronisko w Senra, aby automatycznie otrzymywali alerty o zaginionych zwierzętach, pomagając tworzyć silniejszą sieć bezpieczeństwa dla wszystkich zwierząt w twoim rejonie.";
