// Veiledningselementer
"help_guide_qr_tags_title" = "QR-brikker for kjæledyr";
"help_guide_qr_tags_desc" = "Hver SENRA QR-brikke har en unik QR-kode som lenker til dyrets digitale profil. Alle som finner dyret ditt kan skanne koden med telefonkameraet – ingen app-nedlasting nødvendig. Skanneren ser umiddelbart dyrets bilde, navn, medisinsk informasjon og kontaktopplysningene dine. De kan også dele GPS-posisjonen sin med deg slik at du vet nøyaktig hvor dyret ditt er. QR-brikkene fungerer med alle moderne smarttelefoner.";
"help_guide_materials_title" = "QR-brikkens materiale og holdbarhet";
"help_guide_materials_desc" = "SENRA QR-brikker er laget av holdbart, lett metall med et epoksybelegg for ekstra beskyttelse. De er vanntette og UV-resistente, egnet for alle værforhold. QR-koden er trykt med blekkresistent blekk for å forbli skannbar over tid. QR-brikkene festes trygt til dyrets halsbånd. Hvis en QR-brikke blir skadet eller QR-koden ikke lenger lar seg skanne, kan du bestille erstatning fra kontosiden – gratis for Standard og Maximum.";
"help_guide_emergency_title" = "Nødkontakt og varsler";
"help_guide_emergency_desc" = "Når noen skanner dyrets QR-brikke, mottar du et øyeblikkelig varsel på e-post med finnerens posisjon. Standard og Maximum mottar også SMS-varsler for raskere respons. Hvis du merker dyret ditt som savnet, sendes et fellesskapsvarsel til alle SENRA-brukere innen 10 km, og registrerte veterinærer og dyrevernorganisasjoner i ditt område varsles også. Alle i fellesskapet kan rapportere observasjoner med posisjonen sin, og skaper et spor for å hjelpe deg å finne dyret.";
"help_guide_profile_title" = "Administrasjon av dyreprofil";
"help_guide_profile_desc" = "Dyrets digitale profil er hjertet i SENRA. Legg til viktige detaljer som navn, art, rase, alder og et tydelig bilde. Du kan også inkludere medisinsk informasjon (allergier, medisiner, tilstander), mikrochipnummer og unike kjennetegn som hjelper med å identifisere dyret ditt. Last opp flere bilder til et galleri. All informasjon kan oppdateres når som helst fra seksjonen 'Dyrene mine'. Du kontrollerer hvilke av personopplysningene dine (telefon, e-post, adresse) som vises for folk som skanner QR-brikken.";
"help_guide_missing_alerts_title" = "Savnet-varsler og observasjoner";
"help_guide_missing_alerts_desc" = "Hvis dyret ditt forsvinner, merk det som savnet fra 'Dyrene mine' for å opprette et øyeblikkelig fellesskapsvarsel. Dyrets bilde og detaljer vises på kartet over savnede dyr som er synlig for alle SENRA-brukere i ditt område. Fellesskapsmedlemmer kan rapportere observasjoner med GPS-posisjon, som du mottar som varsler. Registrerte veterinærer og dyrevernorganisasjoner varsles også. Når dyret er funnet, merk det som funnet og del gjerne gjenforeningshistorien din for å inspirere fellesskapet.";
"help_guide_community_title" = "Fellesskap og gjenforente dyr";
"help_guide_community_desc" = "SENRAs styrke er fellesskapet. Kartet over savnede dyr viser aktive varsler i nærheten – sjekk det for å se om noen dyr er rapportert savnet i ditt område. Siden for gjenforente dyr feirer vellykkede gjenforeninger med historier fra dyreeiere. Du kan registrere din lokale veterinær eller dyrevernorganisasjon hos SENRA slik at de mottar savnet-varsler automatisk, og bidrar til å skape et sterkere sikkerhetsnett for alle dyr i ditt område.";

