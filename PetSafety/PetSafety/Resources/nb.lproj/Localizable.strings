// FAQ Questions and Answers
"help_faq_q1" = "Hvordan registrerer jeg kjæledyret mitt?";
"help_faq_a1" = "Du kan registrere kjæledyret ditt i menyen 'Mine Kjæledyr' ved å trykke på 'Legg til Nytt Kjæledyr'. Fyll ut nødvendig informasjon og last opp ett eller flere bilder.";
"help_faq_q2" = "Hvilken informasjon bør jeg oppgi i profilen til kjæledyret mitt?";
"help_faq_a2" = "Du oppga allerede navnet på kjæledyret ditt da du bestilte QR-brikken, og det vil vises i profilen til kjæledyret ditt når QR-brikken er aktivert. Skriv inn art og rase. For å forhindre misbruk kan disse opplysningene bare legges inn én gang. Hvis du gjør en feil, kontakt oss så hjelper vi deg. Her kan du også legge til vekt, alder, farge og eventuelle særtrekk eller typisk atferd. Du kan også laste opp bilder. Du bestemmer hvilken informasjon som er synlig om kjæledyret ditt hvis det blir borte.";
"help_faq_q3" = "Hvordan fungerer QR-brikken?";
"help_faq_a3" = "Hvert kjæledyr får en unik QR-brikke. Koden er knyttet til profilen til kjæledyret ditt. Når noen skanner QR-koden med telefonen, kan de umiddelbart se profilen og kontaktopplysningene du har merket som offentlige.";
"help_faq_q4" = "Kan jeg oppdatere opplysningene om kjæledyret mitt senere?";
"help_faq_a4" = "Ja! Du kan oppdatere opplysningene når som helst i seksjonen 'Mine Kjæledyr' ved å velge kjæledyret og trykke 'Rediger Profil'. Du kan oppdatere alle felt unntatt navn, art og rase, inkludert bilder. Endringer lagres umiddelbart.";
"help_faq_q5" = "Hvordan bestiller jeg et erstatningsmerke?";
"help_faq_a5" = "Gå til 'Hjem / Min konto' og trykk 'Bestill erstatnings-QR-brikke'. Velg hvilket kjæledyr som trenger en ny QR-brikke. Din rett til erstatning avhenger av Senra-kontoen din; besøk senra.pet for detaljer.";
"help_faq_q6" = "Hvordan aktiverer jeg QR-brikken etter at den har kommet?";
"help_faq_a6" = "Last ned SENRA-mobilappen fra Google Play Store eller App Store! Åpne den og gå til menyen 'Aktiver', og rett telefonkameraet mot QR-koden på QR-brikken! Skanning av QR-koden kobler QR-brikken til kontoen din. Deretter må du velge et eksisterende kjæledyr eller opprette en ny profil.";
"help_faq_q7" = "Kan jeg gi en SENRA QR-brikke i gave?";
"help_faq_a7" = "Ja! SENRA QR-brikker er flotte gaver til kjæledyreiere. Bestill QR-brikken fra din egen konto — når mottakeren får den, kan mottakeren skanne QR-koden, opprette sin egen konto og aktivere QR-brikken for sitt kjæledyr.";
"help_faq_q8" = "Hva bør jeg gjøre hvis kjæledyret mitt forsvinner?";
"help_faq_a8" = "Gå til 'Mine Kjæledyr', trykk menyen på kortet til kjæledyret og velg 'Merk som Savnet'. Dette oppretter et 'savnet kjæledyr-varsel' som sendes til alle SENRA-medlemmer innen 10 km. Veterinærer og krisesentre varsles også. Du får umiddelbar varsling for hvert observasjon.";
"help_faq_q9" = "Hvordan fungerer varsler om savnede kjæledyr?";
"help_faq_a9" = "Når du merker katten eller hunden som savnet, opprettes et varsel med bilde og opplysninger. SENRA-brukere innen 10 km varsles umiddelbart og kjæledyret ditt vises på kartet 'Savnede Kjæledyr'. Veterinærer og krisesentre registrert i SENRA-systemet i ditt område mottar også varselet.";
"help_faq_q10" = "Hvordan bestiller jeg et erstatningsmerke?";
"help_faq_a10" = "Gå til 'Hjem/Min Konto' og trykk 'Bestill Erstatningsmerke'. Maximum- og Standard-abonnenter kan be om gratis erstatning, Starter-medlemmer betaler fraktkostnaden.";
"help_faq_q11" = "Hva er henvisningsprogrammet?";
"help_faq_a11" = "I Henvisning-menyen på profilsiden din kan du generere en personlig henvisningskode. Del den med venner og familie. Når noen bruker koden din og abonnerer på en betalt plan (Standard eller Maximum), får du og vennen din 2 måneder gratis.";
"help_faq_q12" = "Hvilke land sender dere til?";
"help_faq_a12" = "Vi sender for tiden til Ungarn, Slovakia, Tsjekkia, Østerrike, Romania, Kroatia, Spania, Italia, Frankrike, Tyskland, Norge og Portugal. Innenlands frakt i Ungarn: {{huPostapoint}} (PostaPont) eller {{huHome}} (hjemmelevering). Internasjonal frakt: {{intlPrice}} per bestilling.";
"help_faq_q13" = "Kan jeg ha flere kjæledyr på én konto?";
"help_faq_a13" = "Ja. Du kan registrere flere kjæledyr på én konto. Besøk senra.pet for kontodetaljer.";
"help_faq_q14" = "Hvordan melder jeg et funnet kjæledyr?";
"help_faq_a14" = "Hvis kjæledyret har en SENRA QR-brikke, skann bare QR-koden med telefonkameraet — ingen app nødvendig. Du kan se profilen og dele posisjonen din med eieren.";
"help_faq_q15" = "Er mine personlige data trygge?";
"help_faq_a15" = "Ja. Du bestemmer nøyaktig hvilke data som er synlige når noen skanner QR-brikken. I 'Innstillinger' > 'Personverninnstillinger' kan du velge om telefonnummer, e-post eller adresse vises. Innloggingen din er beskyttet med en engangskode hver gang. Du kan slette kontoen din når som helst.";
"help_faq_q16" = "Vi mistet QR-brikken eller den ble skadet — hva gjør jeg?";
"help_faq_a16" = "Ingen fare — kjæledyrets digitale profil er trygg og lagres ikke på QR-brikken. Gå til Min side og trykk 'Bestill erstatning'. Vi kobler en ny QR-brikke med en fersk QR-kode til din eksisterende kjæledyrprofil. Din rett til erstatning avhenger av Senra-kontoen din; besøk senra.pet for detaljer. Den gamle QR-brikken deaktiveres umiddelbart når erstatningen bestilles.";
"help_faq_q17" = "Merket mitt skannes ikke — hva gjør jeg?";
"help_faq_a17" = "Prøv følgende: rengjør QR-brikken med en fuktig klut, sørg for god belysning, hold telefonkameraet stabilt omtrent 10–15 cm fra QR-brikken, og sjekk at kameraappen eller QR-leseren virker. Hvis QR-koden er ripete eller slitt, bestill en erstatning fra siden 'Hjem / Min Konto'.";
"help_faq_q18" = "Jeg fant et kjæledyr uten SENRA QR-brikke — hva kan jeg gjøre?";
"help_faq_a18" = "Sjekk kartet over savnede kjæledyr på SENRA-nettstedet (senra.pet) — det kan hende dette kjæledyret allerede er meldt savnet i området ditt. Du kan også se varsler om savnede kjæledyr i appen. Ta kjæledyret med til nærmeste veterinær for å få lest av mikrochippen. Hvis kjæledyret du fant har en SENRA QR-brikke, skann QR-koden med kameraet på telefonen — eierens kontaktinfo dukker opp.";
"help_faq_q19" = "Kan jeg endre e-postadressen min?";
"help_faq_a19" = "Din primære e-postadresse fungerer som kontoidentifikator og kan ikke endres direkte. Du kan legge til en sekundær e-post i 'Innstillinger' > 'Kontaktopplysninger'. Hvis du absolutt må endre primær e-post, kontakt oss på hello@senra.pet.";
"help_faq_q20" = "Hva er forskjellen mellom en mikrochip og en SENRA QR-brikke?";
"help_faq_a20" = "En mikrochip er et lite implantat under kjæledyrets hud som lagrer en unik 15-sifret identifikator — men krever en spesialleser. SENRA QR-brikken kan enkelt skannes med et hvilket som helst smarttelefonkamera, og viser umiddelbart fullstendig profil, bilde og godkjente kontaktopplysninger. Finneren kan også dele GPS-koordinatene.";
"help_faq_q21" = "Hva skjer med dataene mine hvis jeg avslutter abonnementet?";
"help_faq_a21" = "Hvis du avslutter, beholder du tilgang til betalte funksjoner til slutten av gjeldende faktureringsperiode. Deretter byttes kontoen automatisk til gratis Starter-plan. Profiler, bilder og QR-brikker forblir aktive. Dataene slettes ikke. For permanent sletting, bruk Slett Konto i Innstillinger.";
"help_faq_q22" = "Hvordan registrerer jeg klinikken eller krisesenteret mitt hos SENRA?";
"help_faq_a22" = "Veterinærklinikker og krisesentre kan registrere seg på senra.pet/register-vet-shelter. Fyll ut opplysningene, og vi sender en bekreftelses-e-post. Etter bekreftelse sender vi automatisk varsler når kjæledyr blir borte i området. Uten kostnader og uten innlogging.";
"help_faq_q23" = "Hvordan deler jeg en suksesshistorie hvis kjæledyret mitt ble funnet?";
"help_faq_a23" = "Når du merker kjæledyret som 'Funnet', spør vi om du vil dele de gode nyhetene. Du kan publisere en kort historie. Offentlige historier vises på kartet 'Funne Kjæledyr'.";
"help_faq_q24" = "Hvilke nettlesere og enheter støttes?";
"help_faq_a24" = "SENRA fungerer på alle nettlesere, inkludert Chrome, Safari, Firefox og Edge, på mobile og stasjonære enheter. QR-skanning fungerer med et hvilket som helst smarttelefonkamera — finneren trenger ikke SENRA-appen eller en konto.";
"help_faq_q25" = "Kan jeg bestille flere QR-brikker til kjæledyrene mine samtidig?";
"help_faq_a25" = "Ja, du kan bestille QR-brikker til alle kjæledyrene dine samtidig. Etter at QR-brikkene har kommet, skann hver enkelt for å aktivere den og tilordne den til riktig kjæledyrprofil. Du kan også legge inn flere bestillinger når som helst hvis du vil registrere flere kjæledyr senere.";
"help_faq_q26" = "Hvordan når varsler om savnede kjæledyr veterinærer og krisesentre?";
"help_faq_a26" = "Når du merker kjæledyret som 'Savnet', sender SENRA automatisk e-postvarsler til alle registrerte veterinærer og krisesentre i ditt område. Jo flere som er registrert, jo bedre fungerer nettverket.";
"help_faq_q27" = "Kan jeg overføre en QR-brikke til et annet kjæledyr?";
"help_faq_a27" = "Nei. Hver QR-brikke er permanent knyttet til én profil. Hvis et kjæledyr dør eller du ikke lenger trenger QR-brikken, blir den bare inaktiv. Bestill en ny QR-brikke for det nye kjæledyret på SENRA-nettstedet.";
"help_faq_q28" = "Hvordan kan jeg registrere veterinærklinikken til kjæledyret mitt eller krisesenteret der jeg adopterte kjæledyret mitt i SENRA-nettverket?";
"help_faq_a28" = "Veterinærklinikker og krisesentre kan registrere seg på senra.pet/register-vet-shelter. Fyll ut opplysningene, og vi sender en bekreftelses-e-post. Etter bekreftelse sender vi automatisk varsler — og hjelper savnede kjæledyr å komme hjem raskere. Uten kostnader og uten innlogging.";
