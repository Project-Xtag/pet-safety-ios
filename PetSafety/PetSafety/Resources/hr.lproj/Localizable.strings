// FAQ Questions and Answers
"help_faq_q1" = "Kako registriram svog kućnog ljubimca?";
"help_faq_a1" = "Možeš registrirati svog kućnog ljubimca u izborniku 'Moji kućni ljubimci' klikom na 'Dodaj novog kućnog ljubimca'. Ispuni potrebne podatke i učitaj jednu ili više fotografija.";
"help_faq_q2" = "Koje podatke trebam unijeti u profil svog kućnog ljubimca?";
"help_faq_a2" = "Ime svog kućnog ljubimca si unio pri narudžbi privjeska, a ono će se pojaviti u profilu tvog kućnog ljubimca nakon aktivacije privjeska. Unesi vrstu i pasminu svog kućnog ljubimca. Radi sprečavanja zloupotrebe, ovi se podaci mogu unijeti samo jednom. Ako pogriješiš, kontaktiraj nas i pomoći ćemo ti. Ovdje također možeš dodati težinu, dob, boju i bilo koje posebne značajke ili tipično ponašanje svoje mačke/psa. Možeš i učitati fotografije. Ti odlučuješ koji će podaci o tvom kućnom ljubimcu biti vidljivi ako se izgubi.";
"help_faq_q3" = "Kako funkcionira QR privjesak?";
"help_faq_a3" = "Svaki kućni ljubimac dobiva jedinstveni QR privjesak. Ovaj kôd je povezan s profilom tvog kućnog ljubimca. Kada netko skenira QR kôd telefonom, odmah može vidjeti profil i kontaktne podatke koje si označio kao javne.";
"help_faq_q4" = "Mogu li kasnije ažurirati podatke svog kućnog ljubimca?";
"help_faq_a4" = "Da! Možeš ažurirati podatke svog kućnog ljubimca u bilo kojem trenutku u sekciji 'Moji kućni ljubimci' odabirom kućnog ljubimca i klikom na 'Uredi profil'. Možeš ažurirati sva polja osim imena, vrste i pasmine, uključujući fotografije. Promjene se spremaju odmah.";
"help_faq_q5" = "Kako naručim zamjenski privjesak?";
"help_faq_a5" = "Idi na stranicu 'Početna / Moj račun' i klikni 'Naruči zamjenski privjesak'. Odaberi koji kućni ljubimac treba novi privjesak. Pravo na zamjenu ovisi o tvom Senra računu; detalje pronađi na senra.pet.";
"help_faq_q6" = "Kako aktiviram svoj privjesak nakon što stigne?";
"help_faq_a6" = "Preuzmi SENRA mobilnu aplikaciju iz Google Play Store-a ili App Store-a! Otvori je i idi na izbornik 'Aktiviraj', usmjeri kameru telefona na QR kôd na privjesku! Skeniranje QR kôda povezuje privjesak s tvojim računom. Zatim trebaš odabrati postojećeg kućnog ljubimca ili izraditi novi profil.";
"help_faq_q7" = "Mogu li pokloniti SENRA privjesak?";
"help_faq_a7" = "Da! SENRA privjesci su izvrstan poklon za vlasnike kućnih ljubimaca. Jednostavno naruči privjesak sa svog računa — kada ga primatelj primi, može skenirati QR kôd, izraditi vlastiti račun i aktivirati privjesak za svog kućnog ljubimca.";
"help_faq_q8" = "Što trebam učiniti ako moj kućni ljubimac nestane?";
"help_faq_a8" = "Idi na 'Moji kućni ljubimci', klikni izbornik na kartici kućnog ljubimca i odaberi 'Označi kao nestalog'. Ovo stvara 'upozorenje o nestalom kućnom ljubimcu' koje se šalje svim članovima SENRA zajednice registriranima u krugu od 10 km. Obavijesti se i veterinari i skloništa. Za svako viđenje dobivaš trenutnu obavijest.";
"help_faq_q9" = "Kako funkcioniraju upozorenja o nestalim kućnim ljubimcima?";
"help_faq_a9" = "Kada označiš svoju mačku ili psa kao nestalog, stvara se upozorenje s fotografijom i podacima tvog kućnog ljubimca. Korisnici SENRA u krugu od 10 km su odmah obaviješteni i tvoj kućni ljubimac se pojavljuje na karti 'Nestali kućni ljubimci'. Veterinari i skloništa registrirani u sustavu SENRA u tvom području također dobivaju upozorenje.";
"help_faq_q10" = "Kako naručim zamjenski privjesak?";
"help_faq_a10" = "Idi na stranicu 'Početna / Moj račun' i klikni 'Naruči zamjenski privjesak'. Pretplatnici Maximum i Standard mogu zatražiti besplatne zamjene, članovi Starter plaćaju troškove dostave.";
"help_faq_q11" = "Što je program preporuka?";
"help_faq_a11" = "U izborniku Preporuke na stranici Profila možeš generirati osobni kod za preporuku. Podijeli ga s prijateljima i obitelji. Kada netko koristi tvoj kod i pretplati se na plaćeni plan (Standard ili Maximum), ti i tvoj prijatelj dobivate 2 mjeseca besplatno.";
"help_faq_q12" = "U koje zemlje šaljete?";
"help_faq_a12" = "Trenutno šaljemo u Mađarsku, Slovačku, Češku, Austriju, Rumunjsku, Hrvatsku, Španjolsku, Italiju, Francusku, Njemačku, Norvešku i Portugal. Dostava unutar Mađarske: {{huPostapoint}} (PostaPont) ili {{huHome}} (kućna dostava). Međunarodna dostava: {{intlPrice}} po narudžbi.";
"help_faq_q13" = "Mogu li imati više kućnih ljubimaca na jednom računu?";
"help_faq_a13" = "Da. Na jedan račun možeš registrirati više kućnih ljubimaca. Detalje o računu pronađi na senra.pet.";
"help_faq_q14" = "Kako prijavim pronađenog kućnog ljubimca?";
"help_faq_a14" = "Ako kućni ljubimac ima SENRA privjesak, jednostavno skeniraj QR kôd kamerom telefona — nije potrebna aplikacija. Možeš vidjeti profil kućnog ljubimca i podijeliti svoju lokaciju s vlasnikom.";
"help_faq_q15" = "Jesu li moji osobni podaci sigurni?";
"help_faq_a15" = "Da. Ti kontroliraš točno koji su podaci vidljivi kada netko skenira privjesak tvog kućnog ljubimca. U 'Postavke' > 'Postavke privatnosti' možeš odabrati prikazuju li se tvoj telefon, e-mail ili adresa. Tvoja prijava je svaki put zaštićena jednokratnim kôdom. Svoj račun i sve podatke možeš obrisati u bilo kojem trenutku.";
"help_faq_q16" = "Izgubili smo privjesak ili se oštetio — što da radim?";
"help_faq_a16" = "Nema brige — digitalni profil tvog kućnog ljubimca je siguran i ne pohranjuje se na privjesku. Idi na stranicu Račun i klikni 'Naruči zamjenu'. Novi privjesak s novim QR kôdom povežemo s postojećim profilom tvog kućnog ljubimca. Pravo na zamjenu ovisi o tvom Senra računu; detalje pronađi na senra.pet. Stari privjesak se deaktivira odmah po narudžbi zamjene.";
"help_faq_q17" = "Moj privjesak se ne skenira — što da radim?";
"help_faq_a17" = "Pokušaj sljedeće: očisti površinu privjeska vlažnom krpom, osiguraj dobro osvjetljenje, drži kameru telefona mirno oko 10–15 cm od privjeska i provjeri radi li tvoja kamera aplikacija ili QR čitač. Ako je QR kôd ogreban ili istrošen, naruči zamjenu sa stranice 'Početna / Moj račun'.";
"help_faq_q18" = "Pronašao sam kućnog ljubimca bez SENRA privjeska — što mogu učiniti?";
"help_faq_a18" = "Pogledaj kartu Izgubljenih ljubimaca na SENRA web stranici (senra.pet) — možda je ovaj kućni ljubimac već prijavljen kao izgubljen u tvojoj okolici. Obavijesti o izgubljenim ljubimcima možeš pregledati i unutar aplikacije. Odvedi ljubimca do najbliže veterinarske klinike kako bi mu očitali mikročip. Ako pronađeni ljubimac ima SENRA privjesak, skeniraj QR kod kamerom telefona — pojavit će se kontaktni podaci vlasnika.";
"help_faq_q19" = "Mogu li promijeniti svoju email adresu?";
"help_faq_a19" = "Tvoja primarna email adresa služi kao identifikator računa i ne može se izravno promijeniti. Možeš dodati sekundaran email u 'Postavke' > 'Kontakt Podaci'. Ako apsolutno trebaš promijeniti primarni email, kontaktiraj nas na hello@senra.pet.";
"help_faq_q20" = "Koja je razlika između mikročipa i SENRA QR privjeska?";
"help_faq_a20" = "Mikročip je mali implantat pod kožom kućnog ljubimca koji pohranjuje jedinstveni 15-znamenkasti identifikator — ali zahtijeva specijalni čitač. SENRA QR privjesak se može lako skenirati kamerom bilo kojeg pametnog telefona i odmah prikazuje kompletan profil, fotografiju i odobrene kontaktne podatke. Pronalazač može također podijeliti GPS koordinate.";
"help_faq_q21" = "Što se događa s mojim podacima ako otkazem pretplatu?";
"help_faq_a21" = "Ako otkažeš, zadržavaš pristup plaćenim funkcijama do kraja tekućeg razdoblja. Zatim se račun automatski prebacuje na besplatni Starter plan. Profili, fotografije i QR privjesci ostaju aktivni. Podaci se ne brišu. Za trajno brisanje, koristi opciju Obriši račun u Postavkama.";
"help_faq_q22" = "Kako mogu registrirati svoju kliniku ili sklonište u SENRA?";
"help_faq_a22" = "Veterinarske klinike i skloništa se mogu registrirati na senra.pet/register-vet-shelter. Ispuni podatke i šaljemo verifikacijski email. Nakon potvrde automatski šaljemo upozorenja kad u blizini nestanu kućni ljubimci. Bez naknada i bez prijave.";
"help_faq_q23" = "Kako mogu podijeliti priču o uspjehu ako je moj kućni ljubimac pronađen?";
"help_faq_a23" = "Kada označiš kućnog ljubimca kao 'Pronađen', pitamo te želiš li podijeliti dobru vijest. Možeš objaviti kratku priču. Javne priče se pojavljuju na karti 'Pronađeni kućni ljubimci'.";
"help_faq_q24" = "Koji preglednici i uređaji su podržani?";
"help_faq_a24" = "SENRA radi na svim preglednicima, uključujući Chrome, Safari, Firefox i Edge, na mobilnim i desktop uređajima. Skeniranje QR privjeska radi s bilo kojom kamerom pametnog telefona.";
"help_faq_q25" = "Mogu li naručiti više privjesaka za svoje kućne ljubimce odjednom?";
"help_faq_a25" = "Da, možeš naručiti privjeske za sve svoje kućne ljubimce istovremeno. Nakon dolaska, skeniraj svaki za aktivaciju i dodjelu ispravnom profilu.";
"help_faq_q26" = "Kako upozorenja o nestalim kućnim ljubimcima dolaze do veterinara i skloništa?";
"help_faq_a26" = "Kada označiš kućnog ljubimca kao 'Nestalog', SENRA automatski šalje email upozorenja svim registriranim veterinarima i skloništima u tvom području. Što ih je više registrirano, mreža bolje radi.";
"help_faq_q27" = "Mogu li prenijeti privjesak na drugog kućnog ljubimca?";
"help_faq_a27" = "Ne. Svaki QR privjesak je trajno povezan s profilom jednog kućnog ljubimca. Ako kućni ljubimac ugine ili ti privjesak više ne treba, jednostavno postaje neaktivan. Naruči novi privjesak za novog kućnog ljubimca na SENRA stranici.";
"help_faq_q28" = "Kako mogu registrirati veterinarsku kliniku svog kućnog ljubimca ili sklonište u SENRA mrežu?";
"help_faq_a28" = "Veterinarske klinike i skloništa se mogu registrirati na senra.pet/register-vet-shelter. Ispuni podatke i šaljemo verifikacijski email. Nakon potvrde automatski šaljemo upozorenja. Bez naknada i bez prijave.";
