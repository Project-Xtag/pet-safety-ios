// FAQ Items
"help_faq_q1" = "Kako mogu izraditi račun?";
"help_faq_a1" = "SENRA koristi prijavu bez lozinke. Jednostavno unesi svoju e-mail adresu na stranici za prijavu i poslat ćemo ti 6-znamenkasti kod za provjeru. Unesi kod za prijavu. Ako si novi korisnik, račun se automatski izrađuje pri prvoj prijavi — nije potrebna posebna registracija.";
"help_faq_q2" = "Kako mogu registrirati svog ljubimca?";
"help_faq_a2" = "Idi na 'Moji ljubimci' i klikni 'Dodaj ljubimca'. Unesi ime, vrstu, pasminu i dob ljubimca, zatim učitaj fotografiju. Ako si već primio QR pločica, možeš ga skenirati tijekom registracije da ga odmah povežeš s profilom ljubimca.";
"help_faq_q3" = "Koje podatke trebam uključiti u profil ljubimca?";
"help_faq_a3" = "Minimalno dodaj ime, vrstu i jasnu fotografiju ljubimca. Za najbolje šanse brzog pronalaska ako nestane, dodaj i: pasminu, dob, težinu, boju, broj mikročipa, zdravstvene bilješke, alergije, lijekove i posebne značajke (oznake, ožiljci itd.). Što više detalja, to je lakše nekome identificirati tvog ljubimca.";
"help_faq_q4" = "Kako funkcionira QR pločica?";
"help_faq_a4" = "Svaki SENRA pločica ima jedinstveni QR kôd. Kada netko pronađe tvog ljubimca i skenira ga kamerom telefona, odmah vidi profil — fotografiju, ime, zdravstvene podatke i tvoje kontakt podatke. Također mogu podijeliti svoju lokaciju s tobom kako bi znao točno gdje je tvoj ljubimac. Osoba koja skenira ne treba preuzimati aplikaciju.";
"help_faq_q5" = "Što se događa kada netko skenira pločica mog ljubimca?";
"help_faq_a5" = "Skener vidi javni profil tvog ljubimca s podacima koje si odabrao podijeliti (ime, fotografiju, zdravstvene podatke, kontakt podatke). Može kliknuti 'Pronašao sam ovog ljubimca!' da podijeli svoju lokaciju s tobom. Odmah primaš obavijest e-mailom (i SMS-om ako imaš Standard ili Maximum paket) s lokacijom i detaljima pronalazača.";
"help_faq_q6" = "Kako aktiviram pločica nakon što stigne?";
"help_faq_a6" = "Otvori aplikaciju, idi na 'Skeniraj pločica' i usmjeri kameru telefona na QR kôd na pločici. To povezuje pločica s tvojim računom. Zatim ćeš biti upitan da odabereš postojećeg ljubimca ili izradiš novi profil. Nakon aktivacije, odaberi pretplatnički paket.";
"help_faq_q7" = "Mogu li ažurirati podatke o ljubimcu nakon registracije?";
"help_faq_a7" = "Da — profil ljubimca možeš urediti u bilo kojem trenutku. Idi na 'Moji ljubimci', odaberi ljubimca i klikni 'Uredi'. Možeš ažurirati bilo koje polje uključujući fotografije. Promjene se odmah spremaju.";
"help_faq_q8" = "Što učiniti ako moj ljubimac nestane?";
"help_faq_a8" = "Idi na 'Moji ljubimci' i klikni na izbornik na kartici ljubimca, zatim odaberi 'Označi kao nestalog'. To izrađuje uzbunu o nestalom ljubimcu vidljivu SENRA zajednici u tvom području. Korisnici u blizini vidjet će uzbunu i mogu prijaviti viđenja s informacijama o lokaciji. Odmah ćeš biti obaviješten o svakom viđenju.";
"help_faq_q9" = "Kako funkcioniraju uzbune o nestalim ljubimcima?";
"help_faq_a9" = "Kada označiš ljubimca kao nestalog, izrađuje se uzbuna s fotografijom i detaljima. Drugi SENRA korisnici unutar 10 km mogu vidjeti uzbunu na karti nestalih ljubimaca. Svatko u zajednici može prijaviti viđenje, što ti šalje njihovu lokaciju i kontakt podatke. Veterinari i skloništa registrirani na Senri u tvom području također primaju uzbunu.";
"help_faq_q10" = "Kako naručiti zamjenski pločica?";
"help_faq_a10" = "Idi na stranicu Račun i klikni 'Naruči zamjenu'. Odaberi ljubimca kojem treba novi pločica. Maximum pretplatnici dobivaju neograničene besplatne zamjene, Standard pretplatnici jednu besplatnu zamjenu godišnje, a Starter korisnici mogu naručiti zamjene uz malu naknadu za dostavu.";
"help_faq_q11" = "Što je program preporuka?";
"help_faq_a11" = "Na stranici Preporuke generiraj svoj osobni kôd za preporuku. Podijeli ga s prijateljima i obitelji. Kada netko koristi tvoj kôd i pretplati se na plaćeni paket (Standard ili Maximum), oboje dobivate 2 mjeseca besplatno. Status preporuka možeš pratiti na stranici Preporuke.";
"help_faq_q12" = "U koje zemlje dostavljate?";
"help_faq_a12" = "Trenutno dostavljamo u Mađarsku, Slovačku, Češku, Austriju, Rumunjsku, Hrvatsku, Španjolsku i Portugal. Dostava unutar Mađarske košta %1$@ (PostaPont) ili %2$@ (dostava na adresu). Međunarodna dostava je %3$@ po narudžbi.";
"help_faq_q13" = "Mogu li imati više ljubimaca na jednom računu?";
"help_faq_a13" = "Da. Na Starter (besplatnom) paketu možeš registrirati do 10 ljubimaca. Standard paket podržava 1 ljubimca. Maximum paket podržava do 10 ljubimaca. Paket možeš nadograditi u bilo kojem trenutku sa stranice Račun.";
"help_faq_q14" = "Kako prijaviti ljubimca kojeg sam pronašao?";
"help_faq_a14" = "Ako ljubimac ima SENRA pločica, jednostavno skeniraj QR kôd kamerom telefona — aplikacija nije potrebna. Vidjet ćeš profil ljubimca i možeš podijeliti svoju lokaciju s vlasnikom. Ako nema pločice, provjeri kartu nestalih ljubimaca na SENRA web stranici da vidiš je li ljubimac prijavljen kao nestao u tvom području.";
"help_faq_q15" = "Jesu li moji osobni podaci sigurni?";
"help_faq_a15" = "Da. Ti kontroliraš točno koje informacije su vidljive kada netko skenira pločica tvog ljubimca. U Postavke > Privatnost možeš odabrati prikaz ili skrivanje telefonskog broja, e-maila i adrese. Prijava je osigurana jednokratnim kodovima za provjeru — nema lozinki koje se mogu ukrasti. Račun i sve podatke možeš obrisati u bilo kojem trenutku.";
"help_faq_q16" = "Izgubio sam pločica ili je oštećen — što da radim?";
"help_faq_a16" = "Ne brini — digitalni profil tvog ljubimca je siguran i nije pohranjen na samom pločici. Idi na stranicu Račun i klikni 'Naruči zamjenu'. Novi pločica s novim QR kôdom bit će povezan s postojećim profilom ljubimca. Standard pretplatnici dobivaju jednu besplatnu zamjenu godišnje, Maximum pretplatnici neograničene besplatne zamjene, a Starter korisnici plaćaju malu naknadu za dostavu. Stari pločica prestaje raditi nakon aktivacije novog.";
"help_faq_q17" = "Moj pločica se ne skenira — kako to popraviti?";
"help_faq_a17" = "Pokušaj sljedeće: očisti površinu pločice vlažnom krpom, osiguraj dobro osvjetljenje, drži kameru telefona mirno na 10-15 cm od pločice i provjeri radi li aplikacija kamere ili QR skener. Ako je QR kôd ogreban ili izblijedio, možeš koristiti ručni unos kôda u aplikaciji pod 'Skeniraj pločica'. Ako je pločica previše oštećen za čitanje, naruči besplatnu zamjenu sa stranice Račun (Standard i Maximum paketi).";
"help_faq_q18" = "Pronašao sam ljubimca bez SENRA pločice — što mogu učiniti?";
"help_faq_a18" = "Provjeri kartu nestalih ljubimaca na SENRA web stranici (senra.pet) — ljubimac je možda prijavljen kao nestao u tvom području. Možeš pregledati uzbune o nestalim ljubimcima bez računa. Ako pronađeš podudaranje, možeš prijaviti viđenje sa svojom lokacijom da pomogneš spojiti ljubimca s vlasnikom. Također možeš odvesti ljubimca veterinaru na provjeru mikročipa.";
"help_faq_q19" = "Mogu li promijeniti svoju e-mail adresu?";
"help_faq_a19" = "Tvoja primarna e-mail adresa koristi se kao identitet računa i ne može se izravno promijeniti. Ako trebaš koristiti drugi e-mail, možeš dodati sekundarni e-mail u Postavke > Kontakt podaci — on će također biti prikazan na profilu ljubimca. Ako apsolutno trebaš promijeniti primarni e-mail, kontaktiraj naš tim za podršku i pomoći ćemo ti migrirati račun.";
"help_faq_q20" = "Koja je razlika između mikročipa i SENRA QR pločice?";
"help_faq_a20" = "Mikročip je sićušni implantat pod kožom ljubimca koji pohranjuje jedinstveni ID broj — ali zahtijeva poseban čitač (obično dostupan samo kod veterinara i u skloništima). SENRA QR pločica radi odmah s bilo kojom kamerom pametnog telefona, prikazujući potpun profil ljubimca, fotografiju i tvoje kontakt podatke na licu mjesta. Osoba koja pronađe tvog ljubimca može ti podijeliti i svoju GPS lokaciju. Preporučujemo korištenje obojeg: mikročip kao trajnu sigurnosnu kopiju, a SENRA pločica za trenutnu, svakodnevnu identifikaciju.";
"help_faq_q21" = "Što se događa s mojim podacima ako otkažem pretplatu?";
"help_faq_a21" = "Ako otkažeš pretplatu, zadržavaš pristup plaćenim značajkama do kraja tekućeg obračunskog razdoblja. Nakon toga, tvoj račun automatski prelazi na besplatni Starter paket. Profili ljubimaca, fotografije i QR pločice ostaju aktivni — samo gubiš pristup premium značajkama poput SMS obavijesti, veterinarskih uzbuna i besplatnih zamjena pločica. Tvoji podaci se nikad ne brišu kad otkažeš. Za trajno uklanjanje svih podataka, koristi opciju Brisanje računa u Postavkama.";
"help_faq_q22" = "Kako registrirati svog veterinara ili sklonište na Senri?";
"help_faq_a22" = "Veterinari i skloništa mogu se registrirati na senra.pet/register-vet-shelter. Ispuni podatke o klinici ili organizaciji, a mi ćemo poslati e-mail za potvrdu. Nakon potvrde, automatski ćeš primati e-mail uzbune kada ljubimci nestanu u tvom području — pomažeš spojiti nestale ljubimce s njihovim obiteljima. Nema troškova i nije potrebna prijava. Vlasnici ljubimaca također mogu registrirati svog lokalnog veterinara u njihovo ime.";
"help_faq_q23" = "Kako podijeliti priču o uspjehu kada je ljubimac pronađen?";
"help_faq_a23" = "Kada označiš ljubimca kao pronađenog u 'Moji ljubimci', pitat ćemo te želiš li podijeliti svoju priču o spajanju. Možeš dodati kratku poruku o tome kako je ljubimac pronađen i potvrditi lokaciju spajanja. Javne priče pojavljuju se na karti pronađenih ljubimaca, inspirirajući zajednicu i pokazujući da sustav funkcionira. Priču o uspjehu možeš objaviti ili ukloniti i kasnije sa stranice profila ljubimca.";
"help_faq_q24" = "Koji preglednici i uređaji su podržani?";
"help_faq_a24" = "SENRA radi na svim modernim web preglednicima uključujući Chrome, Safari, Firefox i Edge na mobilnim uređajima i stolnim računalima. Skeniranje QR pločice radi s bilo kojom kamerom pametnog telefona — osoba koja pronađe tvog ljubimca ne treba SENRA aplikaciju niti račun. Push obavijesti podržane su u Chromeu i Edgeu na stolnim računalima i Androidu. Za najbolje iskustvo preporučujemo korištenje ažurnog preglednika na telefonu.";
"help_faq_q25" = "Mogu li naručiti pločice za više ljubimaca odjednom?";
"help_faq_a25" = "Svaka narudžba pločica uključuje pločice za imena ljubimaca koje navedeš tijekom naručivanja. Možeš unijeti više imena ljubimaca u jednoj narudžbi. Nakon što pločice stignu, skeniraj svaki za aktivaciju i povezivanje s odgovarajućim profilom ljubimca. Ako ti kasnije trebaju pločice za više ljubimaca, možeš naručiti dodatne sa stranice Račun u bilo kojem trenutku.";
"help_faq_q26" = "Kako uzbune o nestalim ljubimcima dolaze do veterinara i skloništa?";
"help_faq_a26" = "Kada označiš ljubimca kao nestalog, SENRA automatski šalje e-mail uzbune svim verificiranim veterinarima i skloništima registriranim u tvom području. To znači da su lokalni stručnjaci za životinje odmah svjesni da je tvoj ljubimac nestao i mogu paziti na njega. Što je više veterinara i skloništa registrirano u tvom području, jača je sigurnosna mreža. Možeš pomoći potičući svog veterinara da se registrira na Senri.";
"help_faq_q27" = "Mogu li prenijeti pločica na drugog ljubimca?";
"help_faq_a27" = "Svaki QR pločica trajno je povezan s jednim profilom ljubimca i ne može se prenijeti. Ako ljubimac umine ili više ne trebaš pločica, stari pločica jednostavno postaje neaktivan. Za novog ljubimca naruči novi pločica sa stranice Račun. Ako si na Standard ili Maximum paketu, možeš imati pravo na besplatni zamjenski pločica za novog ljubimca.";
// Guide Items
"help_guide_qr_tags_title" = "QR pločice za kućne ljubimce";
"help_guide_qr_tags_desc" = "Svaki SENRA pločica ima jedinstveni QR kôd koji vodi na digitalni profil tvog ljubimca. Svatko tko pronađe tvog ljubimca može skenirati kôd kamerom telefona — nije potrebno preuzimanje aplikacije. Skener odmah vidi fotografiju, ime, zdravstvene podatke i tvoje kontakt podatke. Također mogu podijeliti svoju GPS lokaciju s tobom kako bi znao točno gdje je tvoj ljubimac. Privjesci rade sa svim modernim pametnim telefonima.";
"help_guide_materials_title" = "Materijali i izdržljivost pločice";
"help_guide_materials_desc" = "SENRA pločice izrađeni su od izdržljivog, laganog metala s epoksi premazom za dodatnu zaštitu. Vodootporni su i UV-otporni, prikladni za sve vremenske uvjete. QR kôd otisnut je tintom otpornom na blijeđenje. Privjesci se sigurno pričvršćuju na ogrlicu ljubimca. Ako se pločica ošteti ili QR kôd više nije čitljiv, možeš naručiti zamjenu sa stranice Račun — besplatno za Standard i Maximum pretplatnike.";
"help_guide_emergency_title" = "Hitni kontakt i uzbune";
"help_guide_emergency_desc" = "Kada netko skenira pločica tvog ljubimca, odmah primaš obavijest e-mailom s lokacijom pronalazača. Standard i Maximum pretplatnici također primaju SMS uzbune za brži odgovor. Ako označiš ljubimca kao nestalog, obavijest zajednice šalje se svim SENRA korisnicima unutar 10 km, a registrirani veterinari i skloništa u tvom području također su obaviješteni. Svatko u zajednici može prijaviti viđenja sa svojom lokacijom, gradeći trag za pronalazak tvog ljubimca.";
"help_guide_profile_title" = "Upravljanje profilom ljubimca";
"help_guide_profile_desc" = "Digitalni profil tvog ljubimca srce je Senre. Dodaj bitne podatke poput imena, vrste, pasmine, dobi i jasne fotografije. Možeš uključiti i zdravstvene podatke (alergije, lijekove, stanja), broj mikročipa i posebne značajke. Učitaj više fotografija u galeriju. Sve podatke možeš ažurirati u bilo kojem trenutku iz sekcije 'Moji ljubimci'. Ti kontroliraš koji od tvojih osobnih podataka (telefon, e-mail, adresa) su vidljivi ljudima koji skeniraju pločica.";
"help_guide_missing_alerts_title" = "Uzbune o nestalim ljubimcima i viđenja";
"help_guide_missing_alerts_desc" = "Ako tvoj ljubimac nestane, označi ga kao nestalog iz 'Moji ljubimci' za trenutnu obavijest zajednice. Fotografija i podaci tvog ljubimca pojavljuju se na karti nestalih ljubimaca vidljivoj svim SENRA korisnicima u tvom području. Članovi zajednice mogu prijaviti viđenja sa svojom GPS lokacijom, koja primaš kao obavijesti. Registrirani veterinari i skloništa također su obaviješteni. Kada je ljubimac pronađen, označi ga kao pronađenog i neobavezno podijeli priču o spajanju da inspiriraš zajednicu.";
"help_guide_community_title" = "Zajednica i pronađeni ljubimci";
"help_guide_community_desc" = "Snaga Senre je u njezinoj zajednici. Karta nestalih ljubimaca prikazuje aktivne uzbune u tvojoj blizini — provjeri je da vidiš jesu li ljubimci prijavljeni kao nestali u tvom području. Stranica pronađenih ljubimaca slavi uspješna spajanja s pričama vlasnika. Možeš registrirati svog lokalnog veterinara ili sklonište na Senri kako bi automatski primali uzbune o nestalim ljubimcima, pomažeš izgraditi jaču sigurnosnu mrežu za sve ljubimce u tvom području.";
