// Guide Items
"help_guide_qr_tags_title" = "QR privjesci za kućne ljubimce";
"help_guide_qr_tags_desc" = "Svaki SENRA privjesak ima jedinstveni QR kôd koji vodi na digitalni profil tvog kućnog ljubimca. Svatko tko pronađe tvog kućnog ljubimca može skenirati kôd kamerom telefona — nije potrebno preuzimanje aplikacije. Skener odmah vidi fotografiju, ime, zdravstvene podatke i tvoje kontaktne podatke. Može također s tobom podijeliti GPS lokaciju tako da točno znaš gdje je tvoj kućni ljubimac. Privjesci rade sa svim modernim pametnim telefonima.";
"help_guide_materials_title" = "Materijali i izdržljivost privjeska";
"help_guide_materials_desc" = "SENRA privjesci izrađeni su od izdržljivog, laganog metala s epoksi premazom za dodatnu zaštitu. Vodootporni su i UV-otporni, prikladni za sve vremenske uvjete. QR kôd je tiskan tintom otpornom na habanje kako bi ostao čitljiv. Privjesci se sigurno pričvršćuju na ovratnik kućnog ljubimca. Ako se privjesak ošteti ili QR kôd više nije čitljiv, možeš naručiti zamjenu sa stranice Račun — besplatno za članove Standard i Maximum.";
"help_guide_emergency_title" = "Hitni kontakt i uzbune";
"help_guide_emergency_desc" = "Kada netko skenira privjesak tvog kućnog ljubimca, odmah primaš obavijest e-mailom s lokacijom pronalazača. Standard i Maximum pretplatnici također primaju SMS uzbune za bržu reakciju. Ako označiš kućnog ljubimca kao nestalog, uzbuna zajednice šalje se svim SENRA korisnicima u krugu od 10 km, a obavješćuju se i registrirani veterinari i skloništa u tvom području. Bilo tko iz zajednice može prijaviti viđenje sa svojom lokacijom, gradeći trag koji ti pomaže pronaći kućnog ljubimca.";
"help_guide_profile_title" = "Upravljanje profilom kućnog ljubimca";
"help_guide_profile_desc" = "Digitalni profil tvog kućnog ljubimca srce je SENRA. Dodaj bitne podatke poput imena, vrste, pasmine, dobi i jasne fotografije. Možeš uključiti i zdravstvene podatke (alergije, lijekovi, stanja), broj mikročipa i jedinstvene značajke koje pomažu u identifikaciji tvog kućnog ljubimca. Učitaj više fotografija u galeriju. Svi podaci mogu se ažurirati u bilo kojem trenutku iz sekcije 'Moji kućni ljubimci'. Ti kontroliraš koji tvoji osobni podaci (telefon, e-mail, adresa) su vidljivi ljudima koji skeniraju privjesak.";
"help_guide_missing_alerts_title" = "Uzbune o nestalim kućnim ljubimcima i viđenja";
"help_guide_missing_alerts_desc" = "Ako tvoj kućni ljubimac nestane, označi ga kao nestalog iz 'Moji kućni ljubimci' za trenutnu obavijest zajednice. Fotografija i podaci tvog kućnog ljubimca pojavljuju se na karti nestalih kućnih ljubimaca vidljivoj svim SENRA korisnicima u tvom području. Članovi zajednice mogu prijaviti viđenja sa svojom GPS lokacijom, koja dobivaš kao obavijesti. Registrirani veterinari i skloništa također dobivaju upozorenje. Kada ti se kućni ljubimac pronađe, označi ga kao pronađenog i po želji podijeli svoju priču o spajanju za inspiraciju zajednice.";
"help_guide_community_title" = "Zajednica i pronađeni kućni ljubimci";
"help_guide_community_desc" = "Snaga SENRA je u njezinoj zajednici. Karta nestalih kućnih ljubimaca prikazuje aktivne uzbune u tvojoj blizini — provjeri je da vidiš jesu li kućni ljubimci prijavljeni kao nestali u tvom području. Stranica pronađenih kućnih ljubimaca slavi uspješna spajanja s pričama vlasnika. Možeš registrirati svog lokalnog veterinara ili sklonište za životinje na SENRA da automatski primaju uzbune o nestalim kućnim ljubimcima, pomažući stvoriti jaču sigurnosnu mrežu za sve kućne ljubimce u tvom području.";
