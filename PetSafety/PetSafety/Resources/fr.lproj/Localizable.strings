// FAQ Questions and Answers
"help_faq_q1" = "Comment enregistrer mon animal de compagnie ?";
"help_faq_a1" = "Tu peux enregistrer ton animal de compagnie dans le menu « Mes animaux de compagnie » en appuyant sur « Ajouter un nouvel animal ». Remplis les informations requises et téléverse une ou plusieurs photos.";
"help_faq_q2" = "Quelles informations dois-je fournir dans le profil de mon animal de compagnie ?";
"help_faq_a2" = "Tu as déjà fourni le nom de ton animal de compagnie lors de la commande de la médaille connectée, et il apparaîtra dans le profil de ton animal de compagnie une fois la médaille connectée activée. Saisis l'espèce et la race de ton animal de compagnie. Pour éviter les abus, ces informations ne peuvent être saisies qu'une seule fois. Si tu fais une erreur, contacte-nous et nous t'aiderons. Tu peux également ajouter le poids, l'âge, la couleur et tout trait distinctif ou comportement typique. Tu peux aussi téléverser des photos. Tu décides quelles informations sont visibles concernant ton animal de compagnie s'il se perd.";
"help_faq_q3" = "Comment fonctionne la médaille connectée QR ?";
"help_faq_a3" = "Chaque animal de compagnie reçoit une médaille connectée QR unique. Ce code est lié au profil de ton animal de compagnie. Lorsque quelqu'un scanne le code QR avec son téléphone, il peut immédiatement voir le profil et les coordonnées que tu as marquées comme publiques.";
"help_faq_q4" = "Puis-je mettre à jour les détails de mon animal de compagnie plus tard ?";
"help_faq_a4" = "Oui ! Tu peux mettre à jour les détails de ton animal de compagnie à tout moment dans la section « Mes animaux de compagnie » en sélectionnant ton animal de compagnie et en appuyant sur « Modifier le profil ». Tu peux mettre à jour tous les champs sauf le nom, l'espèce et la race, y compris les photos. Les changements sont enregistrés immédiatement.";
"help_faq_q5" = "Comment commander une médaille connectée de remplacement ?";
"help_faq_a5" = "Va à la page « Accueil / Mon compte » et appuie sur « Commander une médaille connectée de remplacement ». Sélectionne l'animal de compagnie qui a besoin d'une nouvelle médaille connectée. L'éligibilité au remplacement dépend de ton compte SENRA ; visite senra.pet pour plus de détails.";
"help_faq_q6" = "Comment activer ma médaille connectée après sa réception ?";
"help_faq_a6" = "Télécharge l'application mobile SENRA depuis Google Play Store ou App Store ! Ouvre-la et va dans le menu « Activer », puis dirige la caméra de ton téléphone vers le code QR de la médaille connectée ! Scanner le code QR lie la médaille connectée à ton compte. Ensuite, tu dois sélectionner ton animal de compagnie existant ou créer un nouveau profil.";
"help_faq_q7" = "Puis-je offrir une médaille connectée SENRA en cadeau ?";
"help_faq_a7" = "Oui ! Les médailles connectées SENRA sont d'excellents cadeaux pour les propriétaires d'animaux de compagnie. Commande simplement la médaille connectée depuis ton propre compte — lorsque le destinataire la reçoit, il peut scanner le code QR, créer son propre compte et activer la médaille connectée pour son animal de compagnie.";
"help_faq_q8" = "Que dois-je faire si mon animal de compagnie se perd ?";
"help_faq_a8" = "Va dans « Mes animaux de compagnie », appuie sur le menu de la carte de ton animal de compagnie et sélectionne « Marquer comme perdu ». Cela crée une « alerte d'animal de compagnie perdu » envoyée à tous les membres de la communauté SENRA enregistrés dans un rayon de 10 km. Les vétérinaires et refuges sont également notifiés. Tu recevras une notification instantanée pour chaque observation.";
"help_faq_q9" = "Comment fonctionnent les alertes d'animaux de compagnie perdus ?";
"help_faq_a9" = "Lorsque tu marques ton chat ou ton chien comme perdu, une alerte est créée avec la photo et les détails de ton animal de compagnie. Les utilisateurs SENRA dans un rayon de 10 km sont immédiatement notifiés et ton animal de compagnie apparaît sur la carte « Animaux de compagnie perdus ». Les vétérinaires et refuges enregistrés dans le système SENRA de ta région reçoivent également l'alerte.";
"help_faq_q10" = "Comment commander une médaille connectée de remplacement ?";
"help_faq_a10" = "Va à la page « Accueil / Mon compte » et appuie sur « Commander une médaille connectée de remplacement ». Sélectionne l'animal de compagnie qui a besoin d'une nouvelle médaille connectée. Les abonnés Maximum et Standard peuvent demander des remplacements gratuits, les membres Starter paient les frais de port.";
"help_faq_q11" = "Qu'est-ce que le programme de parrainage ?";
"help_faq_a11" = "Dans le menu Parrainage sur ta page de Profil, tu peux générer un code de parrainage personnel. Partage-le avec tes amis et ta famille. Quand quelqu'un utilise ton code et s'abonne à un plan payant (Standard ou Maximum), toi et ton ami obtenez 2 mois gratuits.";
"help_faq_q12" = "Dans quels pays livrez-tu ?";
"help_faq_a12" = "Nous livrons actuellement en Hongrie, Slovaquie, République tchèque, Autriche, Roumanie, Croatie, Espagne, Italie, France, Allemagne, Norvège et Portugal. Livraison nationale en Hongrie : {{huPostapoint}} (PostaPont) ou {{huHome}} (livraison à domicile). Livraison internationale : {{intlPrice}} par commande.";
"help_faq_q13" = "Puis-je avoir plusieurs animaux de compagnie sur un seul compte ?";
"help_faq_a13" = "Oui. Tu peux enregistrer plusieurs animaux de compagnie sur un seul compte. Visite senra.pet pour les détails du compte.";
"help_faq_q14" = "Comment signaler un animal de compagnie trouvé ?";
"help_faq_a14" = "Si l'animal de compagnie a une médaille connectée SENRA, scanne simplement le code QR avec la caméra de ton téléphone — aucune application nécessaire. Tu peux voir le profil de l'animal de compagnie et partager ta position avec le propriétaire.";
"help_faq_q15" = "Mes données personnelles sont-elles en sécurité ?";
"help_faq_a15" = "Oui. Tu contrôles exactement quelles données sont visibles lorsque quelqu'un scanne la médaille connectée de ton animal de compagnie. Dans « Paramètres » > « Paramètres de confidentialité », tu peux choisir si ton numéro de téléphone, ton adresse e-mail ou ton adresse postale sont affichés. Ta connexion est protégée par un code de vérification à usage unique à chaque fois. Tu peux supprimer ton compte et toutes tes données à tout moment.";
"help_faq_q16" = "Nous avons perdu la médaille connectée ou elle est endommagée — que dois-je faire ?";
"help_faq_a16" = "Aucune inquiétude — le profil numérique de ton animal de compagnie est en sécurité et n'est pas stocké sur la médaille connectée. Va à la page Compte et appuie sur « Commander un remplacement ». Nous lierons une nouvelle médaille connectée avec un nouveau code QR à ton profil existant. L'éligibilité au remplacement dépend de ton compte SENRA ; visite senra.pet pour plus de détails. L'ancienne médaille connectée est désactivée immédiatement dès la commande du remplacement.";
"help_faq_q17" = "Ma médaille connectée ne se scanne pas — que dois-je faire ?";
"help_faq_a17" = "Essaie ceci : nettoie la surface de la médaille connectée avec un chiffon humide, assure-toi d'un bon éclairage, tiens la caméra de ton téléphone stable à environ 10–15 cm de la médaille connectée, et vérifie que l'application caméra ou le lecteur QR fonctionne. Si le code QR est rayé ou usé, commande un remplacement depuis la page « Accueil / Mon compte ».";
"help_faq_q18" = "J'ai trouvé un animal de compagnie sans médaille connectée SENRA — que puis-je faire ?";
"help_faq_a18" = "Consulte la carte des Animaux Perdus sur le site SENRA (senra.pet) — cet animal de compagnie a peut-être déjà été signalé perdu dans ta zone. Tu peux aussi voir les alertes d'animaux perdus dans l'application. Emmène l'animal au cabinet vétérinaire le plus proche pour faire scanner sa puce électronique. Si l'animal trouvé porte une médaille connectée SENRA, scanne le code QR avec la caméra de ton téléphone — les coordonnées du propriétaire apparaîtront.";
"help_faq_q19" = "Puis-je changer mon adresse email ?";
"help_faq_a19" = "Ton email principal sert d'identifiant de compte et ne peut pas être changé directement. Tu peux ajouter un email secondaire dans 'Paramètres' > 'Coordonnées'. Si tu as absolument besoin de changer ton email principal, contacte-nous à hello@senra.pet.";
"help_faq_q20" = "Quelle est la différence entre une puce et une médaille connectée QR SENRA ?";
"help_faq_a20" = "Une puce est un petit implant sous la peau de ton animal de compagnie qui stocke un identifiant unique de 15 chiffres — mais nécessite un lecteur spécial. La médaille connectée QR SENRA peut être facilement scannée avec n'importe quel appareil photo de smartphone, et affiche immédiatement le profil complet, la photo et les coordonnées approuvées. Le découvreur peut aussi partager les coordonnées GPS.";
"help_faq_q21" = "Que se passe-t-il avec mes données si j'annule mon abonnement ?";
"help_faq_a21" = "Si tu annules ton abonnement, tu conserves l'accès aux fonctionnalités payantes jusqu'à la fin de la période de facturation en cours. Après cela, ton compte passe automatiquement au plan gratuit Starter. Les profils, photos et médailles connectées QR restent actifs. Les données ne sont pas supprimées. Pour une suppression permanente, utilise l'option Supprimer le compte dans les Paramètres.";
"help_faq_q22" = "Comment enregistrer ma clinique ou mon refuge chez SENRA ?";
"help_faq_a22" = "Les cliniques vétérinaires et refuges peuvent s'inscrire sur senra.pet/register-vet-shelter. Remplis les données et nous envoyons un email de vérification. Après confirmation, nous envoyons automatiquement des notifications quand des animaux se perdent dans la zone. Sans frais et sans inscription.";
"help_faq_q23" = "Comment partager une histoire de succès si mon animal a été retrouvé ?";
"help_faq_a23" = "Quand tu marques ton animal comme 'Retrouvé', nous te demandons si tu veux partager la bonne nouvelle. Tu peux publier une courte histoire. Les histoires publiques apparaissent sur la carte 'Animaux Retrouvés'.";
"help_faq_q24" = "Quels navigateurs et appareils sont supportés ?";
"help_faq_a24" = "SENRA fonctionne sur tous les navigateurs, y compris Chrome, Safari, Firefox et Edge, sur mobile et desktop. Le scan de la médaille connectée QR fonctionne avec n'importe quel appareil photo de smartphone.";
"help_faq_q25" = "Puis-je commander plusieurs médailles connectées pour mes animaux de compagnie en même temps ?";
"help_faq_a25" = "Oui, tu peux commander des médailles connectées pour tous tes animaux de compagnie en même temps. Après réception, scanne chaque médaille connectée pour l'activer et l'attribuer au bon profil.";
"help_faq_q26" = "Comment les alertes d'animaux perdus atteignent-elles les vétérinaires et refuges ?";
"help_faq_a26" = "Lorsque tu marques ton animal de compagnie comme « Perdu », SENRA envoie automatiquement des alertes par e-mail à tous les vétérinaires et refuges enregistrés dans ta région. Plus il y a de vétérinaires et refuges enregistrés, mieux ce réseau fonctionne.";
"help_faq_q27" = "Puis-je transférer une médaille connectée à un autre animal de compagnie ?";
"help_faq_a27" = "Non. Chaque médaille connectée QR est liée en permanence au profil d'un seul animal de compagnie. Si un animal de compagnie décède ou si tu n'as plus besoin de la médaille connectée, l'ancienne médaille connectée devient simplement inactive. Commande une nouvelle médaille connectée pour ton nouvel animal de compagnie sur le site SENRA.";
"help_faq_q28" = "Comment enregistrer la clinique vétérinaire de mon animal ou le refuge où j'ai adopté mon animal dans le réseau SENRA ?";
"help_faq_a28" = "Les cliniques vétérinaires et refuges peuvent s'inscrire sur senra.pet/register-vet-shelter. Remplis les données et nous envoyons un email de vérification. Après confirmation, nous envoyons automatiquement des notifications — aidant les animaux perdus à rentrer chez eux plus vite. Sans frais et sans inscription.";
