// Voci della guida
"help_guide_qr_tags_title" = "Medagliette QR per animali domestici";
"help_guide_qr_tags_desc" = "Ogni medaglietta SENRA è dotata di un QR univoco che rimanda al profilo digitale del tuo animale di compagnia. Chiunque trovi il tuo animale di compagnia può scansionare il codice con la fotocamera del telefono — nessun download di app richiesto. Il lettore vede istantaneamente la foto, il nome, le informazioni mediche e i tuoi recapiti. Può anche condividere la sua posizione GPS con te, così sai esattamente dove si trova il tuo animale di compagnia. Ti medagliette funzionano con tutti gli smartphone moderni.";
"help_guide_materials_title" = "Materiali e durata della medaglietta";
"help_guide_materials_desc" = "Ti medagliette SENRA sono realizzate in metallo resistente e leggero con rivestimento epossidico per una protezione extra. Sono impermeabili e resistenti ai raggi UV, adatte a tutte le condizioni meteorologiche. Il QR è stampato con inchiostro resistente allo sbiadimento per rimanere scansionabile nel tempo. Ti medagliette si fissano saldamente al collare del tuo animale di compagnia. Se una medaglietta si danneggia o il QR non è più scansionabile, puoi ordinare una sostituzione dalla pagina Il mio account — gratuita per i membri dei piani Standard e Maximum.";
"help_guide_emergency_title" = "Contatto d'emergenza e avvisi";
"help_guide_emergency_desc" = "Quando qualcuno scansiona la medaglietta del tuo animale di compagnia, ricevi una notifica istantanea via email con la posizione di chi l'ha trovato. I membri dei piani Standard e Maximum ricevono anche avvisi SMS per una risposta più rapida. Se segni il tuo animale di compagnia come scomparso, viene inviato un avviso alla comunità di tutti gli utenti SENRA nel raggio di 10 km, e i veterinari e rifugi registrati nella tua zona vengono anch'essi notificati. Chiunque nella comunità può segnalare avvistamenti con la propria posizione, creando una traccia per aiutarti a trovare il tuo animale di compagnia.";
"help_guide_profile_title" = "Gestione del profilo dell'animale di compagnia";
"help_guide_profile_desc" = "Il profilo digitale del tuo animale di compagnia è il cuore di SENRA. Aggiungi dettagli essenziali come nome, specie, razza, età e una foto chiara. Puoi anche includere informazioni mediche (allergie, farmaci, condizioni), numero di microchip e caratteristiche uniche che aiutano a identificare il tuo animale di compagnia. Carica più foto in una galleria. Tutte le informazioni possono essere aggiornate in qualsiasi momento dalla sezione 'I miei animali di compagnia'. Controlli quali tuoi dati personali (telefono, email, indirizzo) sono visibili a chi scansiona la medaglietta.";
"help_guide_missing_alerts_title" = "Avvisi di animali di compagnia scomparsi e avvistamenti";
"help_guide_missing_alerts_desc" = "Se il tuo animale di compagnia scompare, segnalo come scomparso da 'I miei animali di compagnia' per creare un avviso istantaneo alla comunità. La foto e i dati del tuo animale di compagnia appaiono sulla mappa degli animali di compagnia scomparsi visibile a tutti gli utenti SENRA nella tua zona. I membri della comunità possono segnalare avvistamenti con la loro posizione GPS, che ricevi come notifiche. Anche i veterinari e i rifugi registrati vengono avvisati. Una volta ritrovato il tuo animale di compagnia, segnalo come ritrovato e condividi opzionalmente la storia del ritrovamento per ispirare la comunità.";
"help_guide_community_title" = "Comunità e animali di compagnia ritrovati";
"help_guide_community_desc" = "La forza di SENRA è la sua comunità. La mappa degli animali di compagnia scomparsi mostra gli avvisi attivi vicino a te — controllala per vedere se sono stati segnalati animali di compagnia scomparsi nella tua zona. La pagina degli animali di compagnia ritrovati celebra i felici ritrovamenti con le storie dei padroni. Puoi registrare il tuo veterinario locale o rifugio animale di compagnia su SENRA in modo che ricevano automaticamente gli avvisi di animali di compagnia scomparsi, contribuendo a creare una rete di sicurezza più solida per tutti gli animali di compagnia nella tua zona.";

