// FAQ Questions and Answers
"help_faq_q1" = "Ako zaregistrujem svojho domáceho miláčika?";
"help_faq_a1" = "Svojho domáceho miláčika môžeš zaregistrovať v menu 'Moji domáci miláčikovia' klepnutím na 'Pridať nového domáceho miláčika'. Vyplň požadované informácie a nahraj jednu alebo viac fotografií.";
"help_faq_q2" = "Aké informácie mám uviesť v profile svojho domáceho miláčika?";
"help_faq_a2" = "Meno svojho domáceho miláčika si zadal pri objednávke známky a po aktivácii známky sa zobrazí v profile tvojho domáceho miláčika. Zadaj druh a plemeno svojho domáceho miláčika. Aby sa predišlo zneužitiu, tieto údaje sa dajú zadať iba raz. Ak urobíš chybu alebo preklep, kontaktuj nás a pomôžeme ti. Tu môžeš zadať aj hmotnosť, vek, farbu a akékoľvek zvláštne znaky alebo typické správanie. Fotografie môžeš nahrať tiež. Ty rozhoduješ, aké informácie budú o tvojom domácom miláčikovi viditeľné v prípade, že sa stratí.";
"help_faq_q3" = "Ako funguje QR známka?";
"help_faq_a3" = "Každý domáci miláčik dostane jedinečnú QR známku. Tento kód je prepojený s profilom tvojho domáceho miláčika. Keď niekto naskenuje QR kód telefónom, okamžite uvidí profil tvojho domáceho miláčika a kontaktné údaje, ktoré si označil ako verejné.";
"help_faq_q4" = "Môžem neskôr aktualizovať údaje svojho domáceho miláčika?";
"help_faq_a4" = "Áno! Údaje svojho domáceho miláčika môžeš kedykoľvek aktualizovať v sekcii 'Moji domáci miláčikovia' výberom domáceho miláčika a klepnutím na 'Upraviť profil'. Môžeš aktualizovať všetky polia okrem mena, druhu a plemena, vrátane fotografií. Zmeny sa uložia okamžite.";
"help_faq_q5" = "Ako si objednám náhradnú známku?";
"help_faq_a5" = "Choď na stránku 'Domov / Môj účet' a klepni na 'Objednať náhradnú známku'. Vyber, ktorý domáci miláčik potrebuje novú známku. Nárok na výmenu závisí od tvojho SENRA účtu; detaily nájdeš na senra.pet.";
"help_faq_q6" = "Ako aktivujem svoju známku po doručení?";
"help_faq_a6" = "Stiahni si SENRA mobilnú aplikáciu z Google Play Store alebo App Store! Otvor ju a choď do menu 'Aktivovať', namier kameru telefónu na QR kód na známke! Naskenovanie QR kódu prepojí známku s tvojím účtom. Potom vyber svojho existujúceho domáceho miláčika alebo vytvor nový profil.";
"help_faq_q7" = "Môžem darovať SENRA známku?";
"help_faq_a7" = "Áno! SENRA známky sú skvelé darčeky pre páníčkov. Jednoducho objednaj známku zo svojho účtu — keď ju obdarovaný dostane, môže naskenovať QR kód, vytvoriť si vlastný účet a aktivovať známku pre svojho domáceho miláčika.";
"help_faq_q8" = "Čo mám robiť, keď sa môj domáci miláčik stratí?";
"help_faq_a8" = "Choď do 'Moji domáci miláčikovia', klepni na menu na karte domáceho miláčika a vyber 'Označiť ako strateného'. Tým sa vytvorí 'upozornenie na strateného domáceho miláčika', ktoré dostanú všetci členovia komunity SENRA registrovaní v okruhu 10 km. Upozornení sú aj veterinári a útulky. Pri každom pozorovaní dostaneš okamžité upozornenie.";
"help_faq_q9" = "Ako fungujú upozornenia na stratených domácich miláčikov?";
"help_faq_a9" = "Keď označíš svoju mačku alebo psa ako strateného, vytvorí sa upozornenie s fotografiou a údajmi tvojho domáceho miláčika. Používatelia SENRA v okruhu 10 km sú okamžite upozornení a tvoj domáci miláčik sa zobrazí na mape 'Stratení domáci miláčikovia'. Veterinári a útulky registrované v systéme SENRA v tvojom okolí tiež dostanú upozornenie.";
"help_faq_q10" = "Ako si objednám náhradnú známku?";
"help_faq_a10" = "Choď na stránku 'Domov / Môj účet' a klepni na 'Objednať náhradnú známku'. Vyber, ktorý domáci miláčik potrebuje novú známku. Predplatitelia Maximum a Standard si môžu vyžiadať bezplatné náhrady, členovia Starter platia za poštovné.";
"help_faq_q11" = "Čo je to odporúčací program?";
"help_faq_a11" = "V menu Odporúčania na stránke svojho profilu môžeš vygenerovať osobný odporúčací kód. Zdieľaj ho s priateľmi a rodinou. Keď niekto použije tvoj kód a predplatí si platený balík (Standard alebo Maximum), ty aj tvoj priateľ získate 2 mesiace zadarmo. Svoje odporúčania a ich stav môžeš sledovať na stránke Odporúčania.";
"help_faq_q12" = "Do ktorých krajín doručujete?";
"help_faq_a12" = "Momentálne doručujeme do Maďarska, Slovenska, Česka, Rakúska, Rumunska, Chorvátska, Španielska, Talianska, Francúzska, Nemecka, Nórska a Portugalska. Domáce doručenie v rámci Maďarska: {{huPostapoint}} (PostaPont) alebo {{huHome}} (doručenie domov). Medzinárodné doručenie: {{intlPrice}} za objednávku.";
"help_faq_q13" = "Môžem mať viac domácich miláčikov na jednom účte?";
"help_faq_a13" = "Áno. Na jeden účet môžeš zaregistrovať viac domácich miláčikov. Detaily o účte nájdeš na senra.pet.";
"help_faq_q14" = "Ako nahlásim nájdeného domáceho miláčika?";
"help_faq_a14" = "Ak má domáci miláčik SENRA známku, jednoducho naskenuj QR kód kamerou telefónu — nie je potrebná žiadna aplikácia. Môžeš si pozrieť profil domáceho miláčika a zdieľať svoju polohu s páníčkom.";
"help_faq_q15" = "Sú moje osobné údaje v bezpečí?";
"help_faq_a15" = "Áno. Ty rozhoduješ, ktoré údaje sú viditeľné, keď niekto naskenuje známku tvojho domáceho miláčika. V 'Nastavenia' > 'Nastavenia súkromia' si môžeš vybrať, či sa zobrazí tvoj telefón, e-mail alebo adresa. Tvoje prihlásenie je chránené jednorazovým overovacím kódom. Svoj účet a všetky údaje môžeš kedykoľvek zmazať.";
"help_faq_q16" = "Stratili sme známku alebo sa poškodila — čo mám robiť?";
"help_faq_a16" = "Žiadne obavy — digitálny profil tvojho domáceho miláčika je v bezpečí a nie je uložený na známke. Choď na stránku Účet a klepni na 'Objednať náhradu'. Prepojíme novú známku s čerstvým QR kódom s tvojím existujúcim profilom domáceho miláčika. Nárok na výmenu závisí od tvojho Senra účtu; detaily na senra.pet. Stará známka sa deaktivuje okamžite pri objednaní náhrady.";
"help_faq_q17" = "Moja známka sa neskenuje — čo mám robiť?";
"help_faq_a17" = "Vyskúšaj nasledovné: očisti povrch známky vlhkou handričkou, zabezpeč dobré osvetlenie, drž kameru telefónu stabilne asi 10–15 cm od známky a skontroluj, či funguje tvoja kamerová aplikácia alebo QR čítačka. Ak je QR kód poškriabaný alebo opotrebovaný, objednaj si náhradu zo stránky 'Domov / Môj účet'.";
"help_faq_q18" = "Našiel som domáceho miláčika bez SENRA známky — čo môžem urobiť?";
"help_faq_a18" = "Pozri si mapu Stratených domácich miláčikov na webe SENRA (senra.pet) — možno bol tento miláčik už nahlásený ako stratený v tvojom okolí. Upozornenia o stratených miláčikoch si môžeš pozrieť aj v aplikácii. Vezmi miláčika k najbližšiemu veterinárovi, aby mu načítali mikročip. Ak má nájdený miláčik známku SENRA, naskenuj QR kód kamerou telefónu — zobrazia sa kontaktné údaje majiteľa.";
"help_faq_q19" = "Môžem zmeniť svoju e-mailovú adresu?";
"help_faq_a19" = "Tvoja primárna e-mailová adresa slúži ako identifikátor účtu, a preto sa nedá priamo zmeniť. Ak chceš ako verejný kontakt použiť iný e-mail, môžeš pridať sekundárnu e-mailovú adresu v 'Nastavenia' > 'Kontaktné údaje' — tá sa môže zobraziť aj v profile tvojho miláčika, ak to povolíš, aby ju nálezca okamžite videl a mohol ťa priamo kontaktovať. Ak nevyhnutne potrebuješ zmeniť primárny e-mail, kontaktuj nás na hello@senra.pet a pomôžeme s migráciou účtu.";
"help_faq_q20" = "Aký je rozdiel medzi mikročipom a SENRA QR známkou?";
"help_faq_a20" = "Mikročip je malý implantát pod kožou domáceho miláčika, ktorý uchováva jedinečný 15-miestny identifikátor — ale vyžaduje špeciálnu čítačku. SENRA QR známka sa dá jednoducho naskenovať akoukoľvek kamerou smartfónu, okamžite zobrazí kompletný profil, fotografiu a tebou schválené kontaktné údaje. Nálezca môže tiež zdieľať GPS súradnice.";
"help_faq_q21" = "Čo sa stane s mojimi údajmi, ak zruším predplatné?";
"help_faq_a21" = "Ak zrušíš predplatné, zachováš si prístup k plateným funkciám do konca aktuálneho fakturačného obdobia. Potom sa tvoj účet automaticky prepne na bezplatný Starter plán. Profily, fotografie a QR známky zostanú aktívne. Údaje sa nezmažú. Na trvalé zmazanie použi možnosť Zmazať účet v Nastaveniach.";
"help_faq_q22" = "Ako môžem zaregistrovať svoju prax alebo útulok v SENRA?";
"help_faq_a22" = "Veterinárne kliniky a útulky sa môžu zaregistrovať na senra.pet/register-vet-shelter. Vyplň údaje a pošleme overovací e-mail. Po potvrdení automaticky posielame upozornenia, keď sa v okolí stratia domáci miláčikovia. Bez poplatkov a bez prihlásenia.";
"help_faq_q23" = "Ako môžem zdieľať príbeh o úspechu, ak bol môj domáci miláčik nájdený?";
"help_faq_a23" = "Keď označíš svojho domáceho miláčika ako 'Nájdeného', pýtame sa, či chceš zdieľať dobrú správu. Môžeš zverejniť krátky príbeh. Verejné príbehy sa zobrazia na mape 'Nájdení domáci miláčikovia'.";
"help_faq_q24" = "Aké prehliadače a zariadenia sú podporované?";
"help_faq_a24" = "SENRA funguje vo všetkých prehliadačoch, vrátane Chrome, Safari, Firefox a Edge, na mobilných aj desktopových zariadeniach. Skenovanie QR známky funguje s akoukoľvek kamerou smartfónu — nálezca nepotrebuje aplikáciu SENRA ani účet.";
"help_faq_q25" = "Môžem si objednať viac známok pre svojich domácich miláčikov naraz?";
"help_faq_a25" = "Áno, môžeš si objednať známky pre všetkých domácich miláčikov naraz. Po doručení známok naskenuj každú pre aktiváciu a priradenie správnemu profilu.";
"help_faq_q26" = "Ako sa upozornenia na stratených domácich miláčikov dostanú k veterinárom a útulkom?";
"help_faq_a26" = "Keď označíš svojho domáceho miláčika ako 'Strateného', SENRA automaticky posiela e-mailové upozornenia všetkým registrovaným veterinárom a útulkom v tvojom okolí. Čím viac ich je zaregistrovaných, tým lepšie sieť funguje.";
"help_faq_q27" = "Môžem preniesť známku na iného domáceho miláčika?";
"help_faq_a27" = "Nie. Každá QR známka je natrvalo prepojená s profilom jedného domáceho miláčika. Ak domáci miláčik zomrie alebo už známku nepotrebuješ, stará známka sa jednoducho stane neaktívnou. Pre nového domáceho miláčika si objednaj novú známku na webe SENRA.";
"help_faq_q28" = "Ako môžem zaregistrovať veterinárnu kliniku svojho domáceho miláčika alebo útulok v sieti SENRA?";
"help_faq_a28" = "Veterinárne kliniky a útulky sa môžu zaregistrovať na senra.pet/register-vet-shelter. Vyplň údaje a pošleme overovací e-mail. Po potvrdení automaticky posielame upozornenia. Bez poplatkov a bez prihlásenia.";
