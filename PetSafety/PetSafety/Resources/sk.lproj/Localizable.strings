// FAQ Questions and Answers
"help_faq_q1" = "Ako zaregistrujem svojho miláčika?";
"help_faq_a1" = "Svojho miláčika môžeš zaregistrovať v menu 'Moji miláčikovia' kliknutím na 'Pridať nového miláčika'. Vyplň požadované informácie a nahraj jednu alebo viac fotografií.";
"help_faq_q2" = "Aké informácie mám uviesť v profile svojho miláčika?";
"help_faq_a2" = "Meno svojho miláčika si zadal pri objednaní známky a po aktivácii známky sa zobrazí v profile tvojho miláčika. Zadaj druh a plemeno svojho miláčika. Na predchádzanie zneužitiu sa tieto údaje dajú zadať len raz. Ak urobíš chybu alebo preklep, kontaktuj nás a pomôžeme ti. Tu môžeš zadať aj hmotnosť, vek, farbu a akékoľvek osobitné znaky alebo typické správanie tvojej mačky/psa. Môžeš nahrať aj fotografie. Tieto môžu pomôcť pri rýchlej identifikácii a bezpečnom návrate tvojho miláčika. Ty rozhoduješ, aké informácie budú o tvojom miláčikovi viditeľné v prípade, že sa stratí.";
"help_faq_q3" = "Ako funguje QR kódová známka?";
"help_faq_a3" = "Každý miláčik dostane unikátnu QR kódovú známku. Tento kód je prepojený s profilom tvojho miláčika. Keď niekto naskenuje QR kód telefónom, okamžite uvidí profil tvojho miláčika a kontaktné údaje, ktoré si označil ako verejné.";
"help_faq_q4" = "Môžem neskôr aktualizovať údaje svojho miláčika?";
"help_faq_a4" = "Áno! Údaje svojho miláčika môžeš kedykoľvek aktualizovať v sekcii 'Moji miláčikovia' výberom miláčika a kliknutím na 'Upraviť profil'. Môžeš aktualizovať všetky polia okrem mena, druhu a plemena, vrátane fotografií. Zmeny sa uložia okamžite.";
"help_faq_q5" = "Ako si objednám náhradnú známku?";
"help_faq_a5" = "Choď na stránku 'Domov/Môj účet' a klikni na 'Objednať náhradnú známku'. Vyber, ktorý miláčik potrebuje novú známku. Predplatitelia Maximum a Standard si môžu vyžiadať bezplatné náhradné známky, zatiaľ čo členovia Starter si môžu objednať náhradu za poštovné.";
"help_faq_q6" = "Ako aktivujem svoju známku po jej doručení?";
"help_faq_a6" = "Stiahni si mobilnú aplikáciu SENRA z Google Play alebo App Store! Otvor ju a choď do menu 'Aktivácia', namieru kameru telefónu na QR kód na známke! Naskenovanie QR kódu prepojí známku s tvojím účtom. Potom musíš vybrať existujúceho miláčika alebo vytvoriť nový profil. Po dokončení aktivácie si môžeš vybrať predplatný balík.";
"help_faq_q7" = "Môžem darovať SENRA známku?";
"help_faq_a7" = "Áno! SENRA známky sú skvelé darčeky pre majiteľov domácich zvierat. Jednoducho objednaj známku zo svojho účtu — keď ju obdarovaný dostane, môže naskenovať QR kód, vytvoriť si vlastný účet a aktivovať známku pre svojho miláčika. Obdarovaný sa nemusí vopred registrovať — naskenovanie známky ho prevedie vytvorením účtu a prepojením známky s jeho miláčikom.";
"help_faq_q8" = "Čo mám robiť, ak sa môj miláčik stratí?";
"help_faq_a8" = "Choď do 'Moji miláčikovia', klikni na menu na karte miláčika a vyber 'Označiť ako strateného'. Tým sa vytvorí 'upozornenie na strateného miláčika', ktoré dostanú všetci členovia komunity SENRA registrovaní v okruhu 10 km. Upozornení sú aj veterinári a útulky. Ľudia v blízkosti vidia upozornenie a môžu ťa informovať, ak videli alebo našli tvojho miláčika (priamo alebo cez náš online systém). Pri každom pozorovaní dostaneš okamžité upozornenie.";
"help_faq_q9" = "Ako fungujú upozornenia na stratených miláčikov?";
"help_faq_a9" = "Keď označíš svoju mačku alebo psa ako strateného, vytvorí sa upozornenie s fotkou a údajmi tvojho miláčika. Používatelia SENRA v okruhu 10 km sú okamžite upozornení a tvoj miláčik sa objaví na mape 'Stratení miláčikovia'. Veterinári a útulky registrované v systéme SENRA v tvojom okolí tiež dostanú upozornenie. Ktokoľvek, kto naskenuje známku tvojho miláčika, ti môže poslať miesto nálezu a svoje kontaktné údaje. Môže ťa kontaktovať aj priamo, ak si sprístupnil kontaktné údaje vo svojom profile.";
"help_faq_q10" = "Ako si objednám náhradnú známku?";
"help_faq_a10" = "Choď na stránku 'Domov/Môj účet' a klikni na 'Objednať náhradnú známku'. Vyber, ktorý miláčik potrebuje novú známku. Predplatitelia Maximum a Standard si môžu vyžiadať bezplatné náhradné známky, zatiaľ čo členovia Starter si môžu objednať náhradu za poštovné.";
"help_faq_q11" = "Čo je to odporúčací program?";
"help_faq_a11" = "V menu Odporúčania na stránke svojho profilu môžeš vygenerovať osobný odporúčací kód. Zdieľaj ho s priateľmi a rodinou. Keď niekto použije tvoj kód a predplatí si platený balík (Standard alebo Maximum), ty aj tvoj priateľ získate 2 mesiace zadarmo. Svoje odporúčania a ich stav môžeš sledovať na stránke Odporúčania.";
"help_faq_q12" = "Do ktorých krajín doručujete?";
"help_faq_a12" = "Momentálne doručujeme do Maďarska, Slovenska, Česka, Rakúska, Rumunska, Chorvátska, Španielska, Talianska, Francúzska, Nemecka, Nórska a Portugalska. Domáce doručenie v rámci Maďarska: {{huPostapoint}} (PostaPont) alebo {{huHome}} (doručenie domov). Medzinárodné doručenie: {{intlPrice}} za objednávku.";
"help_faq_q13" = "Môžem mať viacero miláčikov na jednom účte?";
"help_faq_a13" = "Áno. S balíkom Starter (bezplatný) môžeš zaregistrovať až 10 miláčikov, ale dostupné funkcie sú obmedzené. Balík Standard je navrhnutý pre jednu mačku alebo psa, ale obsahuje všetky funkcie. Balík Maximum zahŕňa všetky funkcie a môžeš zaregistrovať až 10 miláčikov. Balík môžeš kedykoľvek zmeniť v sekcii 'Domov/Môj účet'.";
"help_faq_q14" = "Ako nahlásim nájdeného miláčika?";
"help_faq_a14" = "Ak má miláčik SENRA známku, jednoducho naskenuj QR kód kamerou telefónu — nie je potrebná žiadna aplikácia. Môžeš si pozrieť profil miláčika a zdieľať svoju polohu s majiteľom.";
"help_faq_q15" = "Sú moje osobné údaje v bezpečí?";
"help_faq_a15" = "Áno. Ty určuješ, presne ktoré údaje sú viditeľné, keď niekto naskenuje známku tvojho miláčika. V 'Nastavenia' > 'Nastavenia súkromia' si môžeš vybrať, či sa zobrazí tvoje telefónne číslo, e-mailová adresa alebo domáca adresa. Tvoje prihlásenie je zakaždým chránené jednorazovým overovacím kódom — neexistuje žiadne heslo, ktoré by sa dalo ukradnúť. Svoj účet a všetky údaje môžeš kedykoľvek vymazať.";
"help_faq_q16" = "Stratili sme známku alebo sa poškodila — čo mám robiť?";
"help_faq_a16" = "Neboj sa — digitálny profil tvojho miláčika je v bezpečí a nie je uložený na známke. Choď na stránku Účet a klikni na 'Objednať náhradu'. Prepojíme novú známku s novým QR kódom s tvojím existujúcim profilom miláčika. Predplatitelia Standard a Maximum si môžu vyžiadať neobmedzené bezplatné náhrady, zatiaľ čo členovia Starter musia zaplatiť poštovné. Stará známka sa deaktivuje okamžite pri objednaní náhrady.";
"help_faq_q17" = "Moja známka sa nedá naskenovať — čo mám robiť?";
"help_faq_a17" = "Vyskúšaj nasledovné: vyčisti povrch známky vlhkou handričkou, zabezpeč dobré osvetlenie, drž kameru telefónu stabilne asi 10-15 cm od známky a over, či tvoja kamera alebo QR čítačka funguje. Ak je QR kód poškrabaný alebo opotrebovaný, objednaj bezplatnú náhradu na stránke 'Domov/Môj účet' (bezplatná náhrada je dostupná pre predplatiteľov Standard a Maximum — členovia Starter musia zaplatiť poštovné).";
"help_faq_q18" = "Našiel som miláčika bez SENRA známky — čo môžem urobiť?";
"help_faq_a18" = "Skontroluj mapu Stratených miláčikov na webe SENRA (senra.pet) — miláčik mohol byť nahlásený ako stratený vo tvojom okolí. Upozornenia na stratených miláčikov si môžeš pozrieť aj v aplikácii. Zaves zvieratko k najbližšiemu veterinárovi, aby naskenovali mikročip. Ak má miláčik SENRA známku, naskenuj QR kód kamerou telefónu — zobrazia sa kontaktné údaje majiteľa. Vždy informuj aj miestne úrady a blízke útulky.";
"help_faq_q19" = "Môžem zmeniť svoju e-mailovú adresu?";
"help_faq_a19" = "Tvoja primárna e-mailová adresa slúži ako identifikátor účtu, a preto sa nedá priamo zmeniť. Ak chceš ako verejný kontakt použiť iný e-mail, môžeš pridať sekundárnu e-mailovú adresu v 'Nastavenia' > 'Kontaktné údaje' — tá sa môže zobraziť aj v profile tvojho miláčika, ak to povolíš, aby ju nálezca okamžite videl a mohol ťa priamo kontaktovať. Ak nevyhnutne potrebuješ zmeniť primárny e-mail, kontaktuj nás na hello@senra.pet a pomôžeme s migráciou účtu.";
"help_faq_q20" = "Aký je rozdiel medzi mikročipom a SENRA QR známkou?";
"help_faq_a20" = "Mikročip je malý implantát pod kožou tvojho miláčika, ktorý uchováva unikátny 15-miestny identifikátor — ale vyžaduje špeciálnu čítačku (zvyčajne dostupnú len u veterinárov a v útulkoch). SENRA QR známka sa dá jednoducho naskenovať akoukoľvek kamerou smartfónu, okamžite zobrazí kompletný profil tvojho miláčika, fotku a tebou schválené kontaktné údaje. Nálezca môže tiež zdieľať GPS súradnice miesta nálezu.";
"help_faq_q21" = "Čo sa stane s mojimi údajmi, ak zruším predplatné?";
"help_faq_a21" = "Ak zrušíš predplatné, zachováš si prístup k plateným funkciám do konca aktuálneho fakturačného obdobia. Potom sa tvoj účet automaticky prepne na bezplatný balík Starter. Profily miláčikov, fotky a QR známky zostanú aktívne — stratíš len prístup k prémiovým funkciám (SMS upozornenia, veterinárne upozornenia, bezplatná výmena známky atď.). Tvoje údaje sa pri zrušení nevymažú. Na trvalé vymazanie všetkých údajov použi možnosť Vymazať účet v Nastaveniach.";
"help_faq_q22" = "Ako môžem zaregistrovať svoju prax alebo útulok v SENRA?";
"help_faq_a22" = "Veterinárne praxe a útulky sa môžu zaregistrovať na senra.pet/register-vet-shelter. Vyplň údaje praxe alebo organizácie a my im pošleme overovací e-mail. Po potvrdení im automaticky posielame upozornenia, keď sa v okolí stratia miláčikovia — pomáhajúc strateným miláčikom dostať sa domov. Bez poplatkov a bez nutnosti prihlásenia.";
"help_faq_q23" = "Ako môžem zdieľať úspešný príbeh, ak bol môj miláčik nájdený?";
"help_faq_a23" = "Keď označíš svojho miláčika ako 'Nájdený', opýtame sa ťa, či by si chcel zdieľať dobrú správu s ostatnými. Môžeš zverejniť krátky príbeh o tom, ako bol tvoj miláčik nájdený. Verejné príbehy sa zobrazia na mape 'Nájdení miláčikovia'. Príbeh môžeš zverejniť alebo odstrániť aj neskôr navštívením profilu miláčika.";
"help_faq_q24" = "Aké prehliadače a zariadenia sú podporované?";
"help_faq_a24" = "SENRA funguje vo všetkých prehliadačoch, vrátane Chrome, Safari, Firefox a Edge, na mobilných aj desktopových zariadeniach. Skenovanie QR známky funguje s akoukoľvek kamerou smartfónu — nálezca nepotrebuje aplikáciu SENRA ani účet.";
"help_faq_q25" = "Môžem si objednať viacero známok pre svojich miláčikov naraz?";
"help_faq_a25" = "Áno, môžeš si objednať známky pre všetkých miláčikov naraz. Po doručení známok naskenuj každú z nich na aktiváciu a priradenie k správnemu profilu miláčika. Kedykoľvek môžeš zadať ďalšie objednávky, ak chceš neskôr zaregistrovať ďalších miláčikov.";
"help_faq_q26" = "Ako sa upozornenia na stratených miláčikov dostanú k veterinárom a útulkom?";
"help_faq_a26" = "Keď označíš svojho miláčika ako 'Strateného', SENRA automaticky posiela e-mailové upozornenia všetkým registrovaným veterinárom a útulkom vo tvojom okolí. To znamená, že miestni odborníci sa okamžite dozvedia, že tvoj miláčik je stratený, a môžu ho sledovať. Čím viac veterinárov a útulkov je zaregistrovaných vo tvojom okolí, tým lepšie táto sieť funguje. Môžeš pomôcť tým, že povzbudíš veterinára svojho miláčika, aby sa zaregistroval na webe SENRA.";
"help_faq_q27" = "Môžem previesť známku na iného miláčika?";
"help_faq_a27" = "Nie. Každá QR známka je trvalo prepojená s profilom jedného miláčika. Ak miláčik uhynie alebo už známku nepotrebuješ, stará známka sa jednoducho stane neaktívnou. Pre nového miláčika objednaj novú známku na webe SENRA.";
"help_faq_q28" = "Ako môžem zaregistrovať veterinárnu prax svojho miláčika alebo útulok, odkiaľ som miláčika adoptoval, v sieti SENRA?";
"help_faq_a28" = "Veterinárne praxe a útulky sa môžu zaregistrovať na senra.pet/register-vet-shelter. Vyplň údaje praxe alebo organizácie a my im pošleme overovací e-mail. Po potvrdení im automaticky posielame upozornenia, keď sa v okolí stratia miláčikovia — pomáhajúc strateným miláčikom čo najskôr sa dostať domov. Bez poplatkov a bez nutnosti prihlásenia.";
